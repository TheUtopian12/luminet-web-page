---

<Layout title="Site Map - Luminet">
  <div class="sub-header">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p>Site map</p>
    </div>
  </div>

  <section class="site-map-page">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="site-map-header">
        <span class="subtitle">Site Map</span>
        <h1 class="page-title">Site Map</h1>
      </div>

      <div class="site-map-content">
        {siteMapData.map((section) => (
          <div class="site-map-section">
            <h2 class="section-category-title">{section.title}</h2>
            <div class="category-divider"></div>
            <div class="categories-grid">
              {section.categories.map((cat) => (
                <div class="category-col">
                  <h3>{cat.name}</h3>
                  <ul>
                    {cat.items.map((item) => (
                      <li><a href="#">{item}</a></li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .sub-header {
    background: #1a2a6c;
    padding: 0.8rem 0;
    margin-top: 80px; /* Offset for fixed navbar */
    color: white;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .site-map-page {
    background: #e2e8f0;
    padding: 5rem 0 8rem;
    min-height: 100vh;
  }

  .site-map-header {
    margin-bottom: 4rem;
  }

  .subtitle {
    color: #78BE20;
    font-weight: 700;
    font-size: 0.9rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .page-title {
    color: #0F2E65;
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 800;
  }

  .site-map-content {
    background: white;
    padding: 4rem;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  .site-map-section {
    margin-bottom: 5rem;
  }

  .site-map-section:last-child {
    margin-bottom: 0;
  }

  .section-category-title {
    color: #0F2E65;
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .category-divider {
    width: 100%;
    height: 1px;
    background: #e2e8f0;
    margin-bottom: 3rem;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 3rem 2rem;
  }

  .category-col h3 {
    color: #78BE20;
    font-size: 1.1rem;
    margin-bottom: 1.2rem;
    font-weight: 700;
  }

  .category-col ul {
    list-style: none;
  }

  .category-col ul li {
    margin-bottom: 0.6rem;
    position: relative;
    padding-left: 1.2rem;
  }

  .category-col ul li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: #78BE20;
    font-weight: bold;
  }

  .category-col ul li a {
    font-size: 0.85rem;
    color: #4a5568;
    transition: color 0.3s ease;
  }

  .category-col ul li a:hover {
    color: #78BE20;
    text-decoration: underline;
  }

  @media (max-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }
    .site-map-content {
      padding: 2rem;
    }
  }
</style>
