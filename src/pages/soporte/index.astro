---
import Layout from "../../layouts/Layout.astro";
import { 
  Phone, 
  MessageCircle, 
  Mail, 
  Globe, 
  Clock, 
  Headphones, 
  ArrowRight, 
  ChevronRight, 
  Send, 
  ShieldAlert,
  Server,
  Sparkles,
  HelpCircle,
  HelpCircle as FaqIcon
} from "lucide-astro";

const channels = [
  {
    title: "Teléfono",
    value: "800 123 4567",
    desc: "Llamada gratuita desde cualquier parte del país para soporte inmediato.",
    color: "from-blue-500/20 to-blue-600/5",
    hoverColor: "group-hover:from-blue-500 group-hover:to-blue-600",
    href: "tel:8001234567",
    icon: Phone,
  },
  {
    title: "WhatsApp",
    value: "+52 1 844 123 4567",
    desc: "Respuesta garantizada por técnicos expertos en menos de 15 minutos.",
    color: "from-luminet-lime/20 to-luminet-lime/5",
    hoverColor: "group-hover:from-luminet-lime group-hover:to-luminet-lime-light",
    href: "https://wa.me/5218441234567",
    icon: MessageCircle,
  },
  {
    title: "Email",
    value: "soporte@luminet.com",
    desc: "Envíanos tu reporte detallado para seguimiento de incidentes.",
    color: "from-purple-500/20 to-purple-500/5",
    hoverColor: "group-hover:from-purple-500 group-hover:to-indigo-500",
    href: "mailto:soporte@luminet.com",
    icon: Mail,
  },
  {
    title: "Portal de Clientes",
    value: "clientes.luminet.com",
    desc: "Consulta tus tickets, facturación e historial de servicios en línea.",
    color: "from-orange-500/20 to-orange-500/5",
    hoverColor: "group-hover:from-orange-500 group-hover:to-amber-500",
    href: "#",
    icon: Globe,
  }
];

const availability = [
  {
    title: "Soporte Técnico Especializado",
    schedule: "24 horas / 7 días",
    desc: "Atención ininterrumpida de ingenieros certificados todos los días del año, incluyendo festivos.",
    icon: Headphones
  },
  {
    title: "Línea de Atención a Clientes",
    schedule: "Lun - Vie: 8:00 - 20:00",
    desc: "Horario extendido de atención telefónica para ventas, administración, cambios y consultas generales.",
    icon: Phone
  },
  {
    title: "WhatsApp Corporativo",
    schedule: "24 horas / 7 días",
    desc: "Atención ágil con respuesta en menos de 15 minutos para resolución veloz de incidencias técnicas.",
    icon: MessageCircle
  }
];

const faqs = [
  {
    question: "¿Cuál es el tiempo de respuesta del soporte?",
    answer: "Nuestro equipo de soporte técnico responde en menos de 15 minutos vía WhatsApp y en menos de 1 hora vía correo electrónico. Para incidentes de severidad crítica, la asignación es inmediata con atención prioritaria 24/7."
  },
  {
    question: "¿El soporte técnico tiene un costo adicional?",
    answer: "No, el soporte técnico especializado está totalmente incluido en todos nuestros contratos de servicios empresariales y PyME. No tendrás cargos sorpresa ni cuotas extras por la atención técnica."
  },
  {
    question: "¿Cómo reporto una falla técnica?",
    answer: "Puedes reportar cualquier incidente a través del canal que prefieras: llamando a nuestra línea gratuita, enviando un mensaje directo por WhatsApp, escribiendo un correo electrónico a soporte@luminet.com o abriendo un ticket directamente en nuestro formulario de soporte en línea."
  },
  {
    question: "¿Cuentan con soporte presencial en sitio?",
    answer: "Sí, en caso de que una incidencia no pueda resolverse de manera remota, contamos con cuadrillas de ingenieros certificados listos para realizar visitas técnicas presenciales en tu empresa de forma urgente."
  }
];
---

<Layout title="Soporte Técnico y Contacto - Luminet">
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-luminet-dark">
    <div class="absolute inset-0">
      <div 
        class="absolute inset-0 bg-cover bg-center opacity-40 mix-blend-luminosity" 
        style="background-image: url('https://images.unsplash.com/photo-1553877522-43269d4ea984?w=1920&h=1080&fit=crop');"
      ></div>
      <div class="absolute inset-0 bg-gradient-to-br from-luminet-navy/95 via-luminet-navy/85 to-luminet-navy-dark/95"></div>
      <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-luminet-lime/10 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 left-1/3 w-64 h-64 bg-luminet-lime/5 rounded-full blur-2xl animate-pulse" style="animation-delay: 1s;"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-28 pb-24 md:pt-36 md:pb-32">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-white/50 mb-8 animate-fade-in">
        <a href="/" class="hover:text-luminet-lime transition-colors">Inicio</a>
        <ChevronRight class="w-4 h-4" />
        <span class="text-luminet-lime">Soporte</span>
      </nav>

      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-1.5 text-luminet-lime text-xs font-bold tracking-[0.2em] uppercase mb-4 px-3 py-1 rounded-full bg-luminet-lime/10 border border-luminet-lime/20">
          <Sparkles class="w-3.5 h-3.5" /> Atención al Cliente
        </span>
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.1] mb-5 tracking-tight">
          Centro de <span class="text-luminet-lime">Soporte</span>
        </h1>
        <p class="text-lg md:text-xl text-white/70 leading-relaxed max-w-2xl mb-8">
          Estamos aquí para garantizar que tu negocio nunca se detenga. Nuestro equipo de ingenieros especializados está disponible 24/7/365 para resolver cualquier duda o incidencia con tu servicio de forma inmediata.
        </p>
        
        <div class="flex flex-wrap gap-4">
          <a href="#ticket" class="inline-flex items-center gap-2 px-8 py-4 bg-luminet-lime text-luminet-navy font-bold rounded-full hover:bg-luminet-lime-light hover:scale-105 transition-all duration-300 shadow-lg shadow-luminet-lime/20">
            Abrir ticket de soporte
            <ArrowRight class="w-4 h-4" />
          </a>
          <a href="https://wa.me/5218441234567" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-8 py-4 border border-white/20 hover:border-white/40 text-white font-semibold rounded-full hover:bg-white/5 transition-all duration-300">
            <MessageCircle class="w-4 h-4 text-luminet-lime" />
            WhatsApp Técnico
          </a>
        </div>
      </div>

      <!-- Quick Metrics Grid -->
      <div class="mt-16 flex flex-wrap gap-4">
        <div class="px-6 py-4 bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl min-w-[160px] flex-1 sm:flex-initial">
          <div class="text-2xl font-black text-luminet-lime">24/7</div>
          <div class="text-xs font-semibold text-white/50 tracking-wider uppercase mt-1">Soporte Técnico</div>
        </div>
        <div class="px-6 py-4 bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl min-w-[160px] flex-1 sm:flex-initial">
          <div class="text-2xl font-black text-luminet-lime">&lt; 15 min</div>
          <div class="text-xs font-semibold text-white/50 tracking-wider uppercase mt-1">Tiempo de Respuesta</div>
        </div>
        <div class="px-6 py-4 bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl min-w-[160px] flex-1 sm:flex-initial">
          <div class="text-2xl font-black text-luminet-lime">100%</div>
          <div class="text-xs font-semibold text-white/50 tracking-wider uppercase mt-1">Satisfacción Cliente</div>
        </div>
      </div>
    </div>

    <!-- Decorative Bottom Wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-10 md:h-20" preserveAspectRatio="none">
        <path d="M0 120V60C240 0 480 0 720 30C960 60 1200 90 1440 60V120H0Z" fill="white"></path>
      </svg>
    </div>
  </section>

  <!-- Contact Channels Section -->
  <section class="py-20 md:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-luminet-lime/10 text-luminet-lime text-xs font-bold tracking-wider uppercase mb-3">
          <Phone class="w-3 h-3" /> Contacto Directo
        </span>
        <h2 class="text-3xl md:text-5xl font-extrabold text-luminet-navy tracking-tight">
          Nuestros <span class="text-luminet-lime">Canales de Atención</span>
        </h2>
        <p class="text-gray-500 mt-4 text-lg max-w-2xl mx-auto leading-relaxed">
          Elige la plataforma que te sea más cómoda. Estamos totalmente equipados para brindarte asistencia multicanal con la mayor velocidad.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {channels.map((chan) => (
          <a 
            href={chan.href} 
            target={chan.href.startsWith("http") ? "_blank" : undefined}
            rel={chan.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="group relative p-8 rounded-3xl bg-luminet-gray border border-gray-100 shadow-card hover:shadow-card-hover hover:-translate-y-1.5 transition-all duration-500 overflow-hidden flex flex-col justify-between"
          >
            <!-- Hover Top Accent Stripe -->
            <div class={`absolute top-0 left-0 right-0 h-1 w-0 group-hover:w-full bg-gradient-to-r ${chan.hoverColor} transition-all duration-500`}></div>
            
            <div class="mb-6">
              <!-- Icon Frame with double glow effect -->
              <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${chan.color} flex items-center justify-center mb-6 group-hover:bg-gradient-to-br ${chan.hoverColor} transition-all duration-500 shadow-inner`}>
                <chan.icon class="w-6 h-6 text-luminet-navy group-hover:text-white transition-colors duration-500" />
              </div>
              <h3 class="text-xl font-bold text-luminet-navy mb-2 group-hover:text-luminet-lime transition-colors duration-300">
                {chan.title}
              </h3>
              <p class="text-sm text-gray-400 font-medium mb-3">
                {chan.desc}
              </p>
            </div>
            
            <div class="text-base font-extrabold text-luminet-lime tracking-tight mt-auto">
              {chan.value}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 24/7 Availability Section -->
  <section class="py-20 md:py-28 bg-luminet-navy relative overflow-hidden text-white">
    <!-- Decorative Blurs -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-luminet-lime/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-luminet-lime text-xs font-bold tracking-wider uppercase mb-3">
          <Clock class="w-3 h-3" /> Disponibilidad Permanente
        </span>
        <h2 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight">
          Siempre <span class="text-luminet-lime">Disponibles Para Ti</span>
        </h2>
        <p class="text-white/60 text-lg max-w-2xl mx-auto mt-4 leading-relaxed">
          Entendemos que los imprevistos no tienen horario. Nuestro equipo vela por tu tranquilidad técnica las 24 horas del día.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {availability.map((item) => (
          <div class="p-8 rounded-3xl bg-white/[0.03] border border-white/[0.08] hover:border-luminet-lime/30 hover:bg-white/[0.06] transition-all duration-500 flex flex-col justify-between">
            <div>
              <div class="w-14 h-14 rounded-2xl bg-luminet-lime/10 flex items-center justify-center mb-6 border border-luminet-lime/20">
                <item.icon class="w-6 h-6 text-luminet-lime" />
              </div>
              <h3 class="text-xl font-bold text-white mb-2">{item.title}</h3>
              <p class="text-luminet-lime font-bold text-sm tracking-wide mb-4 inline-block bg-luminet-lime/10 px-3 py-1 rounded-full border border-luminet-lime/20">
                {item.schedule}
              </p>
              <p class="text-sm text-white/55 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ticket Form Section -->
  <section id="ticket" class="py-20 md:py-28 bg-luminet-gray relative overflow-hidden">
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <!-- Ticket Information Side -->
        <div class="lg:col-span-2 lg:sticky lg:top-24">
          <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-luminet-lime/10 text-luminet-lime text-xs font-bold tracking-wider uppercase mb-4">
            <Server class="w-3.5 h-3.5" /> Ticket de Soporte
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-luminet-navy mb-4 tracking-tight">
            Crea un <span class="text-luminet-lime">ticket de soporte</span>
          </h2>
          <p class="text-gray-500 text-lg mb-8 leading-relaxed">
            Reporta un incidente técnico o solicita cambios en tu infraestructura. Nuestro sistema asignará a un especialista certificado y te responderemos en menos de 24 horas con un folio de seguimiento.
          </p>

          <div class="space-y-5">
            <div class="flex items-start gap-4 p-5 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
              <div class="w-12 h-12 rounded-xl bg-luminet-lime/10 flex items-center justify-center shrink-0">
                <Clock class="w-5 h-5 text-luminet-lime" />
              </div>
              <div>
                <h4 class="text-base font-bold text-luminet-navy mb-0.5">Respuesta Prioritaria</h4>
                <p class="text-sm text-gray-500">Confirmación inmediata de recepción y pre-calificación técnica.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-5 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
              <div class="w-12 h-12 rounded-xl bg-luminet-lime/10 flex items-center justify-center shrink-0">
                <ShieldAlert class="w-5 h-5 text-luminet-lime" />
              </div>
              <div>
                <h4 class="text-base font-bold text-luminet-navy mb-0.5">Seguimiento Integrado</h4>
                <p class="text-sm text-gray-500">Recibe actualizaciones del estatus del reporte vía correo.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Ticket Form Side -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-3xl p-8 md:p-10 border border-gray-100 shadow-card">
            
            <!-- Success Message Frame -->
            <div id="ticket-success" class="hidden text-center py-12 px-6">
              <div class="w-20 h-20 bg-luminet-lime/10 text-luminet-lime rounded-full flex items-center justify-center mx-auto mb-6 border border-luminet-lime/20 animate-bounce">
                <Send class="w-8 h-8" />
              </div>
              <h3 class="text-2xl font-extrabold text-luminet-navy mb-3">¡Ticket Creado Con Éxito!</h3>
              <p class="text-gray-500 text-base mb-6 leading-relaxed max-w-md mx-auto">
                Hemos registrado tu reporte correctamente. Un especialista técnico se pondrá en contacto contigo de forma urgente. Tu folio de soporte ha sido enviado a tu email.
              </p>
              <button id="reset-form" class="px-6 py-3 bg-luminet-navy text-white hover:bg-luminet-navy-light font-semibold rounded-full transition-colors">
                Generar otro ticket
              </button>
            </div>

            <!-- Main Form Frame -->
            <form id="support-ticket-form" class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-semibold text-luminet-navy mb-2">Nombre completo <span class="text-red-500">*</span></label>
                  <input 
                    type="text" 
                    name="nombre" 
                    required 
                    class="w-full px-4 py-3.5 rounded-xl border border-gray-200 text-sm text-luminet-navy focus:outline-none focus:border-luminet-lime focus:ring-2 focus:ring-luminet-lime/20 transition-all bg-luminet-gray/50 focus:bg-white" 
                    placeholder="Tu nombre completo"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-luminet-navy mb-2">Email corporativo <span class="text-red-500">*</span></label>
                  <input 
                    type="email" 
                    name="email" 
                    required 
                    class="w-full px-4 py-3.5 rounded-xl border border-gray-200 text-sm text-luminet-navy focus:outline-none focus:border-luminet-lime focus:ring-2 focus:ring-luminet-lime/20 transition-all bg-luminet-gray/50 focus:bg-white" 
                    placeholder="tu@compania.com"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-semibold text-luminet-navy mb-2">Teléfono móvil <span class="text-red-500">*</span></label>
                  <input 
                    type="tel" 
                    name="telefono" 
                    required 
                    class="w-full px-4 py-3.5 rounded-xl border border-gray-200 text-sm text-luminet-navy focus:outline-none focus:border-luminet-lime focus:ring-2 focus:ring-luminet-lime/20 transition-all bg-luminet-gray/50 focus:bg-white" 
                    placeholder="10 dígitos ej. 8441234567"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-luminet-navy mb-2">Nombre de la Compañía <span class="text-red-500">*</span></label>
                  <input 
                    type="text" 
                    name="compania" 
                    required 
                    class="w-full px-4 py-3.5 rounded-xl border border-gray-200 text-sm text-luminet-navy focus:outline-none focus:border-luminet-lime focus:ring-2 focus:ring-luminet-lime/20 transition-all bg-luminet-gray/50 focus:bg-white" 
                    placeholder="Tu empresa"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-semibold text-luminet-navy mb-2">Servicio afectado</label>
                  <select 
                    name="servicio" 
                    class="w-full px-4 py-3.5 rounded-xl border border-gray-200 text-sm text-luminet-navy focus:outline-none focus:border-luminet-lime focus:ring-2 focus:ring-luminet-lime/20 transition-all bg-luminet-gray/50 focus:bg-white cursor-pointer"
                  >
                    <option>Internet Dedicado</option>
                    <option>Internet PyME</option>
                    <option>Internet Satelital</option>
                    <option>Alta Disponibilidad</option>
                    <option>Red WiFi</option>
                    <option>Ciberseguridad</option>
                    <option>SD-WAN</option>
                    <option>Video Vigilancia</option>
                    <option>Otro</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-luminet-navy mb-2">Asunto del reporte <span class="text-red-500">*</span></label>
                  <input 
                    type="text" 
                    name="asunto" 
                    required 
                    class="w-full px-4 py-3.5 rounded-xl border border-gray-200 text-sm text-luminet-navy focus:outline-none focus:border-luminet-lime focus:ring-2 focus:ring-luminet-lime/20 transition-all bg-luminet-gray/50 focus:bg-white" 
                    placeholder="Ej. Enlace intermitente, soporte de IP"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold text-luminet-navy mb-2">Descripción detallada <span class="text-red-500">*</span></label>
                <textarea 
                  name="descripcion" 
                  rows="4" 
                  required 
                  class="w-full px-4 py-3.5 rounded-xl border border-gray-200 text-sm text-luminet-navy focus:outline-none focus:border-luminet-lime focus:ring-2 focus:ring-luminet-lime/20 transition-all bg-luminet-gray/50 focus:bg-white resize-none" 
                  placeholder="Por favor, describe detalladamente la situación para agilizar el diagnóstico técnico..."
                ></textarea>
              </div>

              <button 
                type="submit" 
                class="w-full px-6 py-4 bg-luminet-lime hover:bg-luminet-lime-light text-luminet-navy font-extrabold rounded-xl transition-all duration-300 shadow-lg shadow-luminet-lime/25 flex items-center justify-center gap-2 hover:scale-[1.01] active:scale-[0.99]"
              >
                Crear ticket de soporte
                <Send class="w-4 h-4" />
              </button>
            </form>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section class="py-20 md:py-28 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-luminet-lime/10 text-luminet-lime text-xs font-bold tracking-wider uppercase mb-3">
          <HelpCircle class="w-3.5 h-3.5" /> FAQ
        </span>
        <h2 class="text-3xl md:text-5xl font-extrabold text-luminet-navy tracking-tight">
          Preguntas <span class="text-luminet-lime">Frecuentes</span>
        </h2>
        <p class="text-gray-500 mt-4 text-lg max-w-2xl mx-auto leading-relaxed">
          Encuentra respuestas rápidas a las consultas técnicas más habituales que realizan nuestros clientes.
        </p>
      </div>

      <!-- FAQ Accordion Container -->
      <div class="space-y-4">
        {faqs.map((faq, idx) => (
          <div class="faq-accordion bg-luminet-gray rounded-2xl border border-gray-100 overflow-hidden transition-all duration-300">
            <button 
              type="button"
              class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-gray-100/50 transition-colors duration-300 focus:outline-none"
              data-index={idx}
            >
              <span class="text-base font-bold text-luminet-navy pr-4">
                {faq.question}
              </span>
              <span class="faq-symbol ml-4 shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-lg font-black transition-all duration-300 bg-white text-luminet-navy border border-gray-200">
                +
              </span>
            </button>
            <div class="faq-content hidden px-6 pb-6 border-t border-gray-100/30 pt-4">
              <p class="text-sm sm:text-base text-gray-500 leading-relaxed">
                {faq.answer}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  // Dynamic Ticket Form Handler
  const supportForm = document.getElementById("support-ticket-form") as HTMLFormElement | null;
  const successBox = document.getElementById("ticket-success");
  const resetBtn = document.getElementById("reset-form");

  supportForm?.addEventListener("submit", (e) => {
    e.preventDefault();
    
    // Smooth transition
    supportForm.classList.add("hidden");
    successBox?.classList.remove("hidden");
  });

  resetBtn?.addEventListener("click", () => {
    supportForm?.reset();
    successBox?.classList.add("hidden");
    supportForm?.classList.remove("hidden");
  });

  // Smooth Accordion Handler
  const toggles = document.querySelectorAll(".faq-toggle");
  
  toggles.forEach((btn) => {
    btn.addEventListener("click", () => {
      const parent = btn.closest(".faq-accordion");
      const content = parent?.querySelector(".faq-content");
      const symbol = btn.querySelector(".faq-symbol");
      
      const isOpen = !content?.classList.contains("hidden");
      
      // Close all other accordions first for premium single-select behavior
      document.querySelectorAll(".faq-accordion").forEach((item) => {
        item.querySelector(".faq-content")?.classList.add("hidden");
        const itemSymbol = item.querySelector(".faq-symbol");
        if (itemSymbol) {
          itemSymbol.textContent = "+";
          itemSymbol.classList.remove("bg-luminet-lime", "text-luminet-navy", "border-transparent");
          itemSymbol.classList.add("bg-white", "text-luminet-navy", "border-gray-200");
        }
      });
      
      if (!isOpen) {
        content?.classList.remove("hidden");
        if (symbol) {
          symbol.textContent = "−";
          symbol.classList.add("bg-luminet-lime", "text-luminet-navy", "border-transparent");
          symbol.classList.remove("bg-white", "text-luminet-navy", "border-gray-200");
        }
      }
    });
  });
</script>
