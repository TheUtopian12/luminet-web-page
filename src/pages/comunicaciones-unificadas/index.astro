---
import Layout from '../../layouts/Layout.astro';
import ContactSection from '../../components/home/ContactSection.astro';

const beneficios = [
  { icon: '☁️', title: 'Gestionamiento y Control desde La nube' },
  { icon: '👨‍💻', title: 'Soporte 24/7' },
  { icon: '⚙️', title: 'Acceso de administración compartida con el cliente' },
  { icon: '🤝', title: 'Acompañamiento desde la eleccion hasta la implementacion y soporte de tu servicio' },
];

const faq = [
  { q: '¿En cuánto tiempo instalan?', a: 'Instalamos en tiempo récord una vez contratado el servicio.' },
  { q: '¿Ofrecen soporte 24/7?', a: 'Sí, contamos con soporte técnico especializado disponible las 24 horas.' },
  { q: '¿Pueden integrar múltiples enlaces?', a: 'Sí, podemos gestionar múltiples enlaces.' },
  { q: '¿Como empezaron?', a: 'Luminet nació de la necesidad de ofrecer conectividad empresarial de clase mundial.' },
];
---

<Layout title="Comunicaciones Unificadas - Luminet">
  <section class="service-hero">
    <div class="container hero-container">
      <h1 class="animate-fade-in">Comunicaciones Unificadas</h1>
    </div>
  </section>

  <section class="service-subtitle">
    <div class="container">
      <p>Eleva los resultados e imagen de tu negocio a través del PBX IP Xcien, solución que te ayudará a crear menús de atención por tipo de servicio.</p>
    </div>
  </section>

  <section class="beneficios-luminet">
    <div class="container">
      <h2 class="section-title-center">Beneficios de Luminet</h2>
      <div class="steps-grid">
        <div class="steps-line"></div>
        {beneficios.map((ben) => (
          <div class="step-item">
            <div class="step-icon">{ben.icon}</div>
            <p>{ben.title}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="diferenciadores">
    <div class="container">
      <div class="diferenciadores-card">
        <div class="dif-visual">
          <div class="visual-placeholder">🛰️ ☁️ 📞</div>
        </div>
        <div class="dif-content">
          <h3>Diferenciadores Principales</h3>
          <ul class="dif-list">
            <li>
              <div class="dif-item">
                <strong>Acceso Total</strong>
                <p>Desde cualquier parte del mundo, con un punto o conexión vía Internet.</p>
              </div>
            </li>
            <li>
              <div class="dif-item"><strong>Acceso Multidispositivo</strong></div>
            </li>
            <li>
              <div class="dif-item"><strong>Plataforma de Gestión</strong></div>
            </li>
            <li>
              <div class="dif-item"><strong>Grabación y Almacenamiento</strong></div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <ContactSection />

  <section class="success-cases">
    <div class="container">
      <h2 class="section-title-center">Casos de Éxito</h2>
      <div class="cases-grid">
        <div class="case-card">
          <div class="case-img-placeholder">
             <img src="/success-office.png" alt="Success Case" />
          </div>
          <div class="case-body">
            <h3>Nombre de Marca 1</h3>
            <p>(Descripción del servicio realizado) Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat.</p>
          </div>
        </div>
        <div class="case-card">
          <div class="case-img-placeholder">
             <img src="/success-office.png" alt="Success Case" />
          </div>
          <div class="case-body">
            <h3>Nombre de Marca 2</h3>
            <p>(Descripción del servicio realizado) Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <h2 class="section-title-center">Preguntas Frecuentes</h2>
      <div class="faq-list">
        {faq.map((item) => (
          <details class="faq-item">
            <summary>{item.q} <span class="plus">+</span></summary>
            <div class="faq-answer">
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Same styles as Pyme */
  .service-hero { height: 400px; background: linear-gradient(rgba(0, 8, 41, 0.7), rgba(0, 8, 41, 0.7)), url('/internet-hero.png'); background-size: cover; background-position: center; display: flex; align-items: center; justify-content: center; margin-top: 80px; color: white; }
  .service-hero h1 { font-size: 3.5rem; font-weight: 800; }
  .service-subtitle { padding: 3rem 0; text-align: center; color: #2b59ff; font-weight: 600; font-size: 1.1rem; max-width: 900px; margin: 0 auto; }
  .section-title-center { text-align: center; font-size: 2.5rem; color: #000bb3; margin-bottom: 4rem; }
  .beneficios-luminet { padding: 6rem 0; background: #f8f9fa; }
  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; position: relative; text-align: center; }
  .steps-line { position: absolute; top: 50px; left: 10%; right: 10%; height: 1px; background: #cbd5e0; z-index: 0; }
  .step-item { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
  .step-icon { width: 100px; height: 100px; background: white; border: 1px solid #cbd5e0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; }
  .step-item p { font-weight: 700; color: #000829; font-size: 0.9rem; max-width: 150px; }
  .diferenciadores { padding: 6rem 0; }
  .diferenciadores-card { background: #000bb3; border-radius: 30px; padding: 4rem; display: flex; gap: 4rem; align-items: center; color: white; }
  .dif-visual { flex: 1; display: flex; justify-content: center; align-items: center; }
  .visual-placeholder { font-size: 5rem; }
  .dif-content { flex: 1; }
  .dif-content h3 { font-size: 2rem; margin-bottom: 2.5rem; }
  .dif-list { list-style: none; border-left: 3px solid rgba(255, 255, 255, 0.3); padding-left: 2rem; }
  .dif-item { margin-bottom: 2rem; }
  .dif-item strong { font-size: 1.2rem; display: block; margin-bottom: 0.5rem; }
  .dif-item p { font-size: 0.9rem; opacity: 0.8; }
  .success-cases { padding: 8rem 0; }
  .cases-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .case-card { background: #f8f9fa; border-radius: 20px; overflow: hidden; }
  .case-img-placeholder { height: 250px; }
  .case-img-placeholder img { width: 100%; height: 100%; object-fit: cover; }
  .case-body { padding: 2.5rem; }
  .case-body h3 { color: #000bb3; margin-bottom: 1rem; }
  .case-body p { font-size: 0.9rem; color: #4a5568; line-height: 1.6; }
  .faq-section { padding: 8rem 0; }
  .faq-list { max-width: 900px; margin: 0 auto; }
  .faq-item { border-bottom: 1px solid #e2e8f0; padding: 1.5rem 0; }
  .faq-item summary { list-style: none; font-weight: 700; color: #000bb3; display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
  .faq-answer { padding-top: 1rem; color: #4a5568; }
  @media (max-width: 992px) { .steps-grid, .cases-grid, .diferenciadores-card { grid-template-columns: 1fr; flex-direction: column; } .steps-line { display: none; } }
</style>
