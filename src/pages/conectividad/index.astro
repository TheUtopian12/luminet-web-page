---
import Layout from '../../layouts/Layout.astro';

const solutions = [
  { title: 'Internet Dedicado', desc: 'Contamos con conexiones directas a operadoras de Internet Tier 1.', link: '/internet-dedicado/' },
  { title: 'Internet PYME', desc: 'Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna.', link: '/internet-pyme/' },
  { title: 'Internet Satelital', desc: 'Somos eficientes en la implementación de su servicio.', link: '/internet-satelital/' },
  { title: 'Internet Eventos', desc: 'Contamos con mas de 25 años de experiencia.', link: '/internet-eventos/' },
  { title: 'Alta Disponibilidad', desc: 'Conexión simétrica, estable y dedicada.', link: '/alta-disponibilidad/' },
];

const reasons = [
  { icon: '🎧', title: 'Operadoras Tier 1' },
  { icon: '⚙️', title: 'Rápida Implementación' },
  { icon: '25', title: 'Pioneros de la Industria' },
  { icon: '📡', title: 'Velocidad Garantizada' },
];
---

<Layout title="Conectividad - Luminet">
  <section class="conectividad-hero">
    <div class="container hero-container">
      <h1 class="animate-fade-in">Conectividad</h1>
    </div>
  </section>

  <section class="conectividad-desc">
    <div class="container">
      <p>
        Dale un vistazo a nuestras soluciones en red, dale un vistazo a nuestros trabajos Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi enim ad minim veniam, quis nostrud lobortis nisl ut aliquip ex ea commodo.
      </p>
    </div>
  </section>

  <section class="solutions-grid-section">
    <div class="container">
      <div class="solutions-grid">
        {solutions.map((sol) => (
          <div class="sol-card">
            <div class="sol-card-visual"></div>
            <div class="sol-card-content">
              <h3>{sol.title}</h3>
              <p>{sol.desc}</p>
              <a href={sol.link} class="ver-mas">Ver Mas</a>
            </div>
          </div>
        ))}
        <div class="sol-card contact-cta-card">
          <div class="contact-cta-icon">🎧</div>
          <h3>Contáctenos para más información</h3>
          <div class="cta-btns">
            <a href="#" class="btn btn-white">Enviar Propuesta</a>
            <a href="#" class="btn btn-outline-white">Contactanos</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="success-cases">
    <div class="container">
      <h2 class="section-title-center">Casos de Éxito</h2>
      <div class="cases-grid">
        <div class="case-card">
          <div class="case-img-placeholder">
             <img src="/success-office.png" alt="Success Case" />
          </div>
          <div class="case-body">
            <h3>Nombre de Marca 1</h3>
            <p>(Descripción del servicio realizado)Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi enim ad minim veniam, quis nostrud exerci tation ullamcorper suscipit lobortis nisl ut aliquip ex ea commodo consequat. Duis</p>
          </div>
        </div>
        <div class="case-card">
          <div class="case-img-placeholder">
             <img src="/success-office.png" alt="Success Case" />
          </div>
          <div class="case-body">
            <h3>Nombre de Marca 2</h3>
            <p>(Descripción del servicio realizado)Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi enim ad minim veniam, quis nostrud exerci tation ullamcorper suscipit lobortis nisl ut aliquip ex ea commodo consequat. Duis</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="why-choose-us">
    <div class="container">
      <h2 class="section-title-center small">Por qué elegirnos</h2>
      <div class="reasons-grid">
        {reasons.map((r) => (
          <div class="reason-item">
            <div class="reason-icon">{r.icon}</div>
            <h3>{r.title}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .conectividad-hero {
    height: 400px;
    background: linear-gradient(rgba(0, 8, 41, 0.7), rgba(0, 8, 41, 0.7)), url('/internet-hero.png');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 80px;
    color: white;
  }

  .conectividad-hero h1 {
    font-size: 3.5rem;
    font-weight: 800;
  }

  .conectividad-desc {
    padding: 4rem 0;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .conectividad-desc p {
    font-size: 1rem;
    color: #718096;
    line-height: 1.8;
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding-bottom: 6rem;
  }

  .sol-card {
    background: #f8f9fa;
    border-radius: 20px;
    overflow: hidden;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s ease;
  }

  .sol-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .sol-card-visual {
    height: 120px;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 10px;
    margin-bottom: 1.5rem;
  }

  .sol-card h3 {
    color: #000bb3;
    margin-bottom: 1rem;
    font-size: 1.2rem;
  }

  .sol-card p {
    font-size: 0.85rem;
    color: #4a5568;
    margin-bottom: 2rem;
  }

  .ver-mas {
    color: #2b59ff;
    font-weight: 700;
    font-size: 0.85rem;
  }

  .contact-cta-card {
    background: #000bb3;
    color: white;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .contact-cta-card h3 {
    color: white;
    font-size: 1.4rem;
  }

  .contact-cta-icon {
    font-size: 3rem;
  }

  .cta-btns {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    width: 100%;
  }

  .btn-white {
    background: white;
    color: #000bb3;
    padding: 0.8rem;
    border-radius: 50px;
    font-weight: 700;
  }

  .btn-outline-white {
    border: 1px solid white;
    color: white;
    padding: 0.8rem;
    border-radius: 50px;
    font-weight: 700;
  }

  .section-title-center {
    text-align: center;
    font-size: 2.5rem;
    color: #000bb3;
    margin-bottom: 4rem;
  }

  .section-title-center.small {
    font-size: 1.5rem;
    margin-bottom: 3rem;
  }

  .success-cases {
    padding: 6rem 0;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .case-card {
    background: #f8f9fa;
    border-radius: 20px;
    overflow: hidden;
  }

  .case-img-placeholder {
    height: 250px;
  }

  .case-img-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .case-body {
    padding: 2.5rem;
  }

  .case-body h3 {
    color: #000bb3;
    margin-bottom: 1rem;
  }

  .case-body p {
    font-size: 0.9rem;
    color: #4a5568;
    line-height: 1.6;
  }

  .why-choose-us {
    padding: 6rem 0;
  }

  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .reason-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .reason-item h3 {
    font-size: 0.9rem;
    color: #000bb3;
    max-width: 120px;
    margin: 0 auto;
  }

  @media (max-width: 992px) {
    .solutions-grid, .cases-grid, .reasons-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
