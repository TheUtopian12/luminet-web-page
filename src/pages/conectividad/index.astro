---
import Layout from '../../layouts/Layout.astro';
import { Headphones, Settings, Wifi } from 'lucide-astro';

const solutions = [
  { title: 'Internet Dedicado', desc: 'Contamos con conexiones directas a operadoras de Internet Tier 1.', link: '/internet-dedicado/' },
  { title: 'Internet Asimétrico', desc: 'Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna.', link: '/internet-pyme/' },
  { title: 'Servicios TIC', desc: 'Somos eficientes en la implementación de su servicio.', link: '/internet-satelital/' },
  { title: 'Comunicaciones Unificadas', desc: 'Contamos con mas de 25 años de experiencia.', link: '/internet-eventos/' },
  { title: 'Red WiFi Administrada', desc: 'Conexión simétrica, estable y dedicada.', link: '/alta-disponibilidad/' },
];

const reasons = [
  { Icon: Headphones, title: 'Operadoras Tier 1' },
  { Icon: Settings, title: 'Rápida Implementación' },
  { text: '25', title: 'Pioneros de la Industria' },
  { Icon: Wifi, title: 'Velocidad Garantizada' },
];
---

<Layout title="Conectividad - Luminet">
  <section class="conectividad-hero">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 hero-container">
      <h1 class="animate-fade-in">Conectividad</h1>
    </div>
  </section>

  <section class="conectividad-desc">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p>
        Dale un vistazo a nuestras soluciones en red, dale un vistazo a nuestros trabajos Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi enim ad minim veniam, quis nostrud lobortis nisl ut aliquip ex ea commodo.
      </p>
    </div>
  </section>

  <section class="solutions-grid-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="solutions-grid">
        {solutions.map((sol) => (
          <div class="sol-card">
            <div class="sol-card-visual"></div>
            <div class="sol-card-content">
              <h3>{sol.title}</h3>
              <p>{sol.desc}</p>
              <a href={sol.link} class="ver-mas">Ver Mas</a>
            </div>
          </div>
        ))}
        <div class="sol-card contact-cta-card">
          <div class="contact-cta-icon"><Headphones /></div>
          <h3>Contáctenos para más información</h3>
          <div class="cta-btns">
            <a href="#" class="btn btn-white">Enviar Propuesta</a>
            <a href="#" class="btn btn-outline-white">Contactanos</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="success-cases">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title-center">Casos de Éxito</h2>

      <div class="cases-layout" id="casos-exito" data-paused>
        <div class="cases-selector" role="tablist" aria-label="Selector de casos de éxito">
          <div class="cases-orbit cases-orbit-1" aria-hidden="true"></div>
          <div class="cases-orbit cases-orbit-2" aria-hidden="true"></div>

          <svg class="cases-star-lines" viewBox="0 0 300 300" preserveAspectRatio="xMidYMid meet" aria-hidden="true" focusable="false">
            <defs>
              <linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#78BE20" stop-opacity="0.7"/>
                <stop offset="100%" stop-color="#0F2E65" stop-opacity="0.5"/>
              </linearGradient>
              <radialGradient id="centerHalo" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#78BE20" stop-opacity="0.22"/>
                <stop offset="60%" stop-color="#78BE20" stop-opacity="0.06"/>
                <stop offset="100%" stop-color="#78BE20" stop-opacity="0"/>
              </radialGradient>
            </defs>

            <circle cx="150" cy="155" r="105" fill="url(#centerHalo)"/>

            <path d="M 150 40 Q 220 60 265 123" fill="none" stroke="url(#lineGrad)" stroke-width="1.3" stroke-dasharray="2 8" stroke-linecap="round" opacity="0.7"/>
            <path d="M 265 123 Q 270 200 221 260" fill="none" stroke="url(#lineGrad)" stroke-width="1.3" stroke-dasharray="2 8" stroke-linecap="round" opacity="0.7"/>
            <path d="M 221 260 Q 150 280 79 260" fill="none" stroke="url(#lineGrad)" stroke-width="1.3" stroke-dasharray="2 8" stroke-linecap="round" opacity="0.7"/>
            <path d="M 79 260 Q 30 200 35 123" fill="none" stroke="url(#lineGrad)" stroke-width="1.3" stroke-dasharray="2 8" stroke-linecap="round" opacity="0.7"/>
            <path d="M 35 123 Q 80 60 150 40" fill="none" stroke="url(#lineGrad)" stroke-width="1.3" stroke-dasharray="2 8" stroke-linecap="round" opacity="0.7"/>

            <circle cx="150" cy="155" r="22" fill="#ffffff" stroke="rgba(15,46,101,0.15)" stroke-width="1"/>
            <circle cx="150" cy="155" r="14" fill="none" stroke="#78BE20" stroke-opacity="0.4" stroke-width="1" stroke-dasharray="2 3"/>
            <circle cx="150" cy="155" r="8" fill="#78BE20" fill-opacity="0.15"/>
            <circle cx="150" cy="155" r="5" fill="#78BE20"/>
          </svg>

          <button class="case-circle pos-top active" data-case="coahuila"
            role="tab" id="tab-coahuila" aria-controls="panel-coahuila" aria-selected="true" tabindex="0">
            <img class="case-circle-img" src="/casosExito/gob_coahuila.webp" alt="" width="100" height="100" decoding="async" />
            <span class="sr-only">Gobierno de Coahuila</span>
            <span class="case-pulse" aria-hidden="true"></span>
          </button>
          <button class="case-circle pos-upper-right" data-case="monterrey"
            role="tab" id="tab-monterrey" aria-controls="panel-monterrey" aria-selected="false" tabindex="-1">
            <img class="case-circle-img" src="/casosExito/gob_mty.webp" alt="" width="100" height="100" loading="lazy" decoding="async" />
            <span class="sr-only">Gobierno de Monterrey</span>
            <span class="case-pulse" aria-hidden="true"></span>
          </button>
          <button class="case-circle pos-lower-right" data-case="quintana-roo"
            role="tab" id="tab-quintana-roo" aria-controls="panel-quintana-roo" aria-selected="false" tabindex="-1">
            <img class="case-circle-img" src="/casosExito/gob_quintana.webp" alt="" width="100" height="100" loading="lazy" decoding="async" />
            <span class="sr-only">Quintana Roo</span>
            <span class="case-pulse" aria-hidden="true"></span>
          </button>
          <button class="case-circle pos-lower-left" data-case="oaxaca"
            role="tab" id="tab-oaxaca" aria-controls="panel-oaxaca" aria-selected="false" tabindex="-1">
            <img class="case-circle-img" src="/casosExito/gob_oaxaca.webp" alt="" width="100" height="100" loading="lazy" decoding="async" />
            <span class="sr-only">Gobierno de Oaxaca</span>
            <span class="case-pulse" aria-hidden="true"></span>
          </button>
          <button class="case-circle pos-upper-left" data-case="uadec"
            role="tab" id="tab-uadec" aria-controls="panel-uadec" aria-selected="false" tabindex="-1">
            <img class="case-circle-img" src="/casosExito/uni_coahuila.webp" alt="" width="100" height="100" loading="lazy" decoding="async" />
            <span class="sr-only">Universidad Autónoma de Coahuila</span>
            <span class="case-pulse" aria-hidden="true"></span>
          </button>
        </div>

        <div class="case-detail">
          <div class="case-detail-card" data-case-detail="coahuila" id="panel-coahuila" role="tabpanel" aria-labelledby="tab-coahuila">
            <div class="case-detail-img">
              <img src="/success-office.png" alt="Gobierno de Coahuila" width="560" height="420" loading="lazy" decoding="async" />
            </div>
            <div class="case-detail-body">
              <span class="case-detail-eyebrow">Caso de éxito</span>
              <h3>Gobierno del Estado de Coahuila de Zaragoza</h3>
              <ul>
                <li>Servicios especializados de salud mediante videollamada en 133 centros.</li>
                <li>Sistema de gestión (documentación y trámite) para los Notarios y el Instituto Catastral. Rediseño del sistema, se desarrolló el código y se entregó una herramienta de escritorio y plataforma móvil.</li>
                <li>Migración de plataforma (Pago Fácil) de administración de pagos de servidores en físico a la Nube. Análisis y diseño de nuevas capacidades para su implementación.</li>
              </ul>
            </div>
          </div>

          <div class="case-detail-card" data-case-detail="monterrey" id="panel-monterrey" role="tabpanel" aria-labelledby="tab-monterrey" hidden>
            <div class="case-detail-img">
              <img src="/success-office.png" alt="Gobierno de Monterrey" width="560" height="420" loading="lazy" decoding="async" />
            </div>
            <div class="case-detail-body">
              <span class="case-detail-eyebrow">Caso de éxito</span>
              <h3>Gobierno de Monterrey</h3>
              <ul>
                <li>Mantenimiento de circuito cerrado de televisión (CCTV).</li>
                <li>Desarrollo de red Fibra Óptica y red GPON.</li>
              </ul>
            </div>
          </div>

          <div class="case-detail-card" data-case-detail="quintana-roo" id="panel-quintana-roo" role="tabpanel" aria-labelledby="tab-quintana-roo" hidden>
            <div class="case-detail-img">
              <img src="/success-office.png" alt="Quintana Roo" width="560" height="420" loading="lazy" decoding="async" />
            </div>
            <div class="case-detail-body">
              <span class="case-detail-eyebrow">Caso de éxito</span>
              <h3>Quintana Roo</h3>
              <ul>
                <li>Mantenimiento de circuito cerrado de televisión (CCTV) en centros penitenciarios.</li>
                <li>Sistemas de inspección por Rayos X.</li>
                <li>Terminales digitales portátiles; soluciones de extremo a extremo para seguridad pública.</li>
              </ul>
            </div>
          </div>

          <div class="case-detail-card" data-case-detail="oaxaca" id="panel-oaxaca" role="tabpanel" aria-labelledby="tab-oaxaca" hidden>
            <div class="case-detail-img">
              <img src="/success-office.png" alt="Oaxaca" width="560" height="420" loading="lazy" decoding="async" />
            </div>
            <div class="case-detail-body">
              <span class="case-detail-eyebrow">Caso de éxito</span>
              <h3>Gobierno del Estado de Oaxaca</h3>
              <ul>
                <li>Diseño de red P25 para la Secretaría de Seguridad Pública.</li>
              </ul>
            </div>
          </div>

          <div class="case-detail-card" data-case-detail="uadec" id="panel-uadec" role="tabpanel" aria-labelledby="tab-uadec" hidden>
            <div class="case-detail-img">
              <img src="/success-office.png" alt="Universidad Autónoma de Coahuila" width="560" height="420" loading="lazy" decoding="async" />
            </div>
            <div class="case-detail-body">
              <span class="case-detail-eyebrow">Caso de éxito</span>
              <h3>Universidad Autónoma de Coahuila</h3>
              <ul>
                <li>Potentes equipos de respaldo, junto con servidores de almacenamiento de alta capacidad.</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const root = document.getElementById('casos-exito');
      if (!root) return;

      const tabs = Array.from(root.querySelectorAll('[role="tab"]'));
      const panels = Array.from(root.querySelectorAll('[role="tabpanel"]'));
      const prefersReduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
      let isAnimating = false;

      const panelByCase = new Map(
        panels.map((p) => [p.dataset.caseDetail, p])
      );

      function selectTab(nextTab, focusTab = false) {
        if (isAnimating) return;
        if (nextTab.getAttribute('aria-selected') === 'true') {
          if (focusTab) nextTab.focus();
          return;
        }

        const target = nextTab.dataset.case;
        const current = panels.find((p) => !p.hidden);
        const next = panelByCase.get(target);
        if (!next) return;

        tabs.forEach((t) => {
          const selected = t === nextTab;
          t.setAttribute('aria-selected', selected ? 'true' : 'false');
          t.tabIndex = selected ? 0 : -1;
          t.classList.toggle('active', selected);
        });

        if (focusTab) nextTab.focus();

        if (!current || current === next || prefersReduced) {
          panels.forEach((p) => { p.hidden = p !== next; });
          return;
        }

        isAnimating = true;
        current.classList.add('is-leaving');
        current.addEventListener('animationend', function onLeave() {
          current.removeEventListener('animationend', onLeave);
          current.classList.remove('is-leaving');
          current.hidden = true;
          next.hidden = false;
          next.classList.add('is-entering');
          next.addEventListener('animationend', function onEnter() {
            next.removeEventListener('animationend', onEnter);
            next.classList.remove('is-entering');
            isAnimating = false;
          });
        });
      }

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => selectTab(tab));
        tab.addEventListener('keydown', (e) => {
          const i = tabs.indexOf(tab);
          let next = null;
          if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
            next = tabs[(i + 1) % tabs.length];
          } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
            next = tabs[(i - 1 + tabs.length) % tabs.length];
          } else if (e.key === 'Home') {
            next = tabs[0];
          } else if (e.key === 'End') {
            next = tabs[tabs.length - 1];
          }
          if (next) {
            e.preventDefault();
            selectTab(next, true);
          }
        });
      });

      // Pausar animaciones cuando la sección está fuera de viewport
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              root.removeAttribute('data-paused');
            } else {
              root.setAttribute('data-paused', '');
            }
          });
        }, { threshold: 0.05 });
        io.observe(root);
      } else {
        root.removeAttribute('data-paused');
      }
    })();
  </script>

  <section class="why-choose-us">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title-center small">Por qué elegirnos</h2>
      <div class="reasons-grid">
        {reasons.map((r) => (
          <div class="reason-item">
            <div class="reason-icon">{r.Icon ? <r.Icon /> : r.text}</div>
            <h3>{r.title}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .conectividad-hero {
    min-height: 400px; padding: 4rem 0;
    background: linear-gradient(rgba(15, 46, 101, 0.7), rgba(15, 46, 101, 0.7)), url('/internet-hero.png');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 80px;
    color: white;
  }

  .conectividad-hero h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 800;
  }

  .conectividad-desc {
    padding: 4rem 0;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .conectividad-desc p {
    font-size: 1rem;
    color: #718096;
    line-height: 1.8;
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding-bottom: 6rem;
  }

  .sol-card {
    background: #f8f9fa;
    border-radius: 20px;
    overflow: hidden;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s ease;
  }

  .sol-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .sol-card-visual {
    height: 120px;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 10px;
    margin-bottom: 1.5rem;
  }

  .sol-card h3 {
    color: #0F2E65;
    margin-bottom: 1rem;
    font-size: 1.2rem;
  }

  .sol-card p {
    font-size: 0.85rem;
    color: #4a5568;
    margin-bottom: 2rem;
  }

  .ver-mas {
    color: #78BE20;
    font-weight: 700;
    font-size: 0.85rem;
  }

  .contact-cta-card {
    background: #0F2E65;
    color: white;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .contact-cta-card h3 {
    color: white;
    font-size: 1.4rem;
  }

  .contact-cta-icon {
    font-size: 3rem;
  }

  .cta-btns {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    width: 100%;
  }

  .btn-white {
    background: white;
    color: #0F2E65;
    padding: 0.8rem;
    border-radius: 50px;
    font-weight: 700;
  }

  .btn-outline-white {
    border: 1px solid white;
    color: white;
    padding: 0.8rem;
    border-radius: 50px;
    font-weight: 700;
  }

  .section-title-center {
    text-align: center;
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    color: #0F2E65;
    margin-bottom: 4rem;
  }

  .section-title-center.small {
    font-size: 1.5rem;
    margin-bottom: 3rem;
  }

  .success-cases {
    padding: 6rem 0;
  }

  /* Casos de éxito - selector + detalle */
  .cases-layout {
    display: grid;
    grid-template-columns: minmax(380px, 460px) 1fr;
    gap: 3rem;
    align-items: center;
  }

  .cases-selector {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 500px;
    margin: 0 auto;
    padding: 0;
  }

  /* Helper accesible para texto solo lector */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .cases-orbit {
    position: absolute;
    border-radius: 50%;
    border: 1px dashed rgba(15, 46, 101, 0.08);
    pointer-events: none;
    z-index: 0;
    animation-play-state: paused;
  }

  .cases-orbit-1 {
    inset: 18%;
    animation: orbit-spin 60s linear infinite;
  }

  .cases-orbit-2 {
    inset: 8%;
    border-style: solid;
    border-color: rgba(120, 190, 32, 0.06);
    animation: orbit-spin 90s linear infinite reverse;
  }

  [data-paused] .cases-orbit,
  [data-paused] .case-pulse {
    animation-play-state: paused !important;
  }

  .cases-layout:not([data-paused]) .cases-orbit {
    animation-play-state: running;
  }

  @keyframes orbit-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .cases-star-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  .case-circle {
    position: absolute;
    z-index: 2;
    width: 130px;
    height: 130px;
    border-radius: 50%;
    border: none;
    background:
      linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: box-shadow 0.35s ease, transform 0.35s ease, filter 0.35s ease;
    padding: 0;
    box-shadow:
      inset 0 0 0 2px #0F2E65,
      0 8px 20px rgba(15, 46, 101, 0.12),
      0 2px 4px rgba(15, 46, 101, 0.06);
    overflow: hidden;
    filter: saturate(0.95);
  }

  .case-ring {
    display: none;
  }

  /* Posiciones en estrella (pentágono): top, ur, lr, ll, ul */
  .pos-top        { top: 2%;   left: 50%; --tx: -50%; --ty: 0; transform: translate(var(--tx), var(--ty)); }
  .pos-upper-right{ top: 32%;  right: 2%; --tx: 0;    --ty: -50%; transform: translate(var(--tx), var(--ty)); }
  .pos-lower-right{ bottom: 2%; right: 12%; --tx: 0;  --ty: 0; transform: translate(var(--tx), var(--ty)); }
  .pos-lower-left { bottom: 2%; left: 12%; --tx: 0;   --ty: 0; transform: translate(var(--tx), var(--ty)); }
  .pos-upper-left { top: 32%;  left: 2%;  --tx: 0;    --ty: -50%; transform: translate(var(--tx), var(--ty)); }

  .case-circle:hover,
  .case-circle:focus-visible {
    filter: saturate(1.1);
    box-shadow:
      inset 0 0 0 2px #78BE20,
      0 0 0 4px rgba(120, 190, 32, 0.12),
      0 12px 28px rgba(120, 190, 32, 0.22);
    transform: translate(var(--tx), var(--ty)) scale(1.04);
    outline: none;
  }

  .case-circle:focus-visible {
    box-shadow:
      inset 0 0 0 2px #78BE20,
      0 0 0 4px rgba(120, 190, 32, 0.35),
      0 12px 28px rgba(120, 190, 32, 0.28);
  }

  .case-circle.active {
    filter: saturate(1.1);
    background: linear-gradient(180deg, #ffffff 0%, #f7fbed 100%);
    box-shadow:
      inset 0 0 0 3px #78BE20,
      0 0 0 8px rgba(120, 190, 32, 0.14),
      0 16px 34px rgba(120, 190, 32, 0.35),
      0 4px 8px rgba(15, 46, 101, 0.08);
    transform: translate(var(--tx), var(--ty)) scale(1.1);
    z-index: 3;
  }


  .case-pulse {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 2px solid #78BE20;
    opacity: 0;
    pointer-events: none;
  }

  .case-circle.active .case-pulse {
    animation: case-ring-pulse 1.8s ease-out infinite;
  }

  @keyframes case-ring-pulse {
    0%   { transform: scale(1);    opacity: 0.6; }
    100% { transform: scale(1.45); opacity: 0; }
  }

  .case-circle-inner {
    font-size: 0.9rem;
    font-weight: 700;
    color: #0F2E65;
    text-align: center;
    line-height: 1.25;
    padding: 0 0.75rem;
    letter-spacing: 0.01em;
    transition: color 0.3s ease;
    position: relative;
    z-index: 1;
  }

  .case-circle.active .case-circle-inner {
    color: #5a9410;
  }

  .case-circle-img {
    width: 72%;
    height: 72%;
    max-width: 72%;
    max-height: 72%;
    object-fit: contain;
    pointer-events: none;
    transition: transform 0.3s ease;
    display: block;
  }

  .case-circle:hover .case-circle-img {
    transform: scale(1.05);
  }

  .case-detail {
