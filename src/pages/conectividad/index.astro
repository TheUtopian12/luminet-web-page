---
import Layout from '../../layouts/Layout.astro';
import { Headphones, Plus, ShieldCheck, RadioTower, Award, MapPin, Building2, Code2 } from 'lucide-astro';

const diferenciadores = [
  { Icon: ShieldCheck, text: 'Empresa concesionada y regulada por el IFT' },
  { Icon: RadioTower, text: 'Operador de enlaces en microondas más grande de México' },
  { Icon: Award, text: 'Certificaciones en instalación y operación de Fibra Óptica' },
  { Icon: MapPin, text: 'Red propia en 12 estados claves de la República' },
  { Icon: Building2, text: '26+ años de experiencia en sector público' },
  { Icon: Code2, text: 'Software propio — no dependemos de plataformas de terceros' },
];

const solutions = [
  { title: 'Internet Dedicado', desc: 'Contamos con conexiones directas a operadoras de Internet Tier 1.', link: '/internet-dedicado/', img: '/conectividad/1.webp' },
  { title: 'Internet Asimétrico', desc: 'Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna.', link: '/internet-pyme/', img: '/conectividad/2.webp' },
  { title: 'Servicios TIC', desc: 'Somos eficientes en la implementación de su servicio.', link: '/internet-satelital/', img: '/conectividad/3.webp' },
  { title: 'Comunicaciones Unificadas', desc: 'Contamos con mas de 25 años de experiencia.', link: '/internet-eventos/', img: '/conectividad/4.webp' },
  { title: 'Red WiFi Administrada', desc: 'Conexión simétrica, estable y dedicada.', link: '/alta-disponibilidad/', img: '/conectividad/5.webp' },
];

// Casos de éxito sobre el mapa interactivo de México.
// left/top: posición del pin en % del lienzo (viewBox 0 150 1024 724 → left = x/1024, top = (y-150)/724).
const casos = [
  {
    id: 'coahuila',
    estado: 'Coahuila',
    title: 'Gobierno del Estado de Coahuila de Zaragoza',
    logo: '/casosExito/gob_coahuila.webp',
    img: '/casosExito/imgGobCoa.webp',
    left: 38.6, top: 24.9,
    tagline: 'Caso más completo — múltiples servicios',
    desc: 'Telemedicina en 133 centros, sistema de gestión notarial y catastral, y migración de Pago Fácil a la nube.',
  },
  {
    id: 'monterrey',
    estado: 'Nuevo León',
    title: 'Gobierno de Monterrey',
    logo: '/casosExito/gob_mty.webp',
    img: '/casosExito/imgGobMTY.webp',
    left: 49.8, top: 29.7,
    tagline: 'Infraestructura urbana',
    desc: 'Circuito cerrado de televisión (CCTV) y desarrollo de red de Fibra Óptica y GPON.',
  },
  {
    id: 'quintana-roo',
    estado: 'Quintana Roo',
    title: 'Quintana Roo',
    logo: '/casosExito/gob_quintana.webp',
    img: '/casosExito/imgGobRoo.webp',
    left: 93.6, top: 67.7,
    tagline: 'Seguridad pública especializada',
    desc: 'CCTV en centros penitenciarios, sistemas de inspección por Rayos X y terminales de seguridad pública.',
  },
  {
    id: 'oaxaca',
    estado: 'Oaxaca',
    title: 'Gobierno del Estado de Oaxaca',
    logo: '/casosExito/gob_oaxaca.webp',
    img: '/casosExito/imgGobOax.webp',
    left: 61.0, top: 90.0,
    tagline: 'Radiocomunicación policial',
    desc: 'Red P25 para la Secretaría de Seguridad Pública.',
  },
  {
    id: 'uadec',
    estado: 'Coahuila',
    title: 'Universidad Autónoma de Coahuila',
    logo: '/casosExito/uni_coahuila.webp',
    img: '/casosExito/imgUniCoa.webp',
    left: 42.0, top: 31.8,
    tagline: 'Infraestructura TI institucional',
    desc: 'Servidores y almacenamiento de alta capacidad.',
  },
];
---

<Layout title="Conectividad - Luminet">
  <section class="conectividad-hero">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 hero-container">
      <h1 class="animate-fade-in">Conectividad</h1>
    </div>
  </section>

  <section class="conectividad-desc">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p>
        Dale un vistazo a nuestras soluciones en red, dale un vistazo a nuestros trabajos Lorem ipsum dolor sit amet, consectetuer adipiscing elit, sed diam nonummy nibh euismod tincidunt ut laoreet dolore magna aliquam erat volutpat. Ut wisi enim ad minim veniam, quis nostrud lobortis nisl ut aliquip ex ea commodo.
      </p>
    </div>
  </section>

  <section class="solutions-grid-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="solutions-grid">
        {solutions.map((sol) => (
          <div class="sol-card">
            <div class="sol-card-visual">
              <img src={sol.img} alt={sol.title} width="320" height="200" loading="lazy" decoding="async" />
            </div>
            <div class="sol-card-content">
              <h3>{sol.title}</h3>
              <p>{sol.desc}</p>
              <a href={sol.link} class="ver-mas">Ver Mas</a>
            </div>
          </div>
        ))}
        <div class="sol-card contact-cta-card">
          <div class="contact-cta-icon"><Headphones /></div>
          <h3>Contáctenos para más información</h3>
          <div class="cta-btns">
            <a href="#" class="btn btn-white">Enviar Propuesta</a>
            <a href="#" class="btn btn-outline-white">Contactanos</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="success-cases">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-title-center">Casos de Éxito</h2>

      <div class="cases-grid" id="casos-exito">
        {casos.map((c) => (
          <article
            class="case-tile"
            role="button"
            tabindex="0"
            aria-expanded="false"
            aria-label={`Caso de éxito: ${c.title}`}
          >
            <img class="case-tile-img" src={c.img} alt={c.title} width="560" height="420" loading="lazy" decoding="async" />
            <span class="case-tile-scrim" aria-hidden="true"></span>
            <span class="case-tile-tag">{c.estado}</span>

            <div class="case-tile-head">
              <span class="case-tile-cat">{c.tagline}</span>
              <h3 class="case-tile-title">{c.title}</h3>
              <span class="case-tile-more">
                Ver detalle <Plus class="case-tile-icon" />
              </span>
            </div>

            <div class="case-tile-detail">
              <span class="case-detail-eyebrow">{c.tagline}</span>
              <h3>{c.title}</h3>
              <p class="case-tile-desc">{c.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const root = document.getElementById('casos-exito');
      if (!root) return;

      const tiles = Array.from(root.querySelectorAll('.case-tile'));

      function setOpen(tile, open) {
        tile.classList.toggle('is-open', open);
        tile.setAttribute('aria-expanded', open ? 'true' : 'false');
      }

      function toggle(tile) {
        const willOpen = !tile.classList.contains('is-open');
        // Solo una tarjeta abierta a la vez (modo clic / teclado)
        tiles.forEach((t) => { if (t !== tile) setOpen(t, false); });
        setOpen(tile, willOpen);
      }

      tiles.forEach((tile) => {
        tile.addEventListener('click', () => toggle(tile));
        tile.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            toggle(tile);
          } else if (e.key === 'Escape') {
            setOpen(tile, false);
          }
        });
      });
    })();
  </script>

  <section class="diferenciadores-section">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="dif-header">
        <p class="dif-eyebrow">Nuestro respaldo</p>
        <h2>Por qué confiar en nosotros</h2>
        <span class="dif-underline" aria-hidden="true"></span>
      </div>
      <ul class="diferenciadores-grid">
        {diferenciadores.map(({ Icon, text }) => (
          <li class="dif-card">
            <span class="dif-icon"><Icon /></span>
            <p>{text}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>

<style>
  .conectividad-hero {
    min-height: 400px; padding: 4rem 0;
    background: linear-gradient(rgba(15, 46, 101, 0.7), rgba(15, 46, 101, 0.7)), url('/internet-hero.png');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 80px;
    color: white;
  }

  .conectividad-hero h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 800;
  }

  .conectividad-desc {
    padding: 4rem 0;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .conectividad-desc p {
    font-size: 1rem;
    color: #718096;
    line-height: 1.8;
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding-bottom: 6rem;
  }

  .sol-card {
    background: #f8f9fa;
    border-radius: 20px;
    overflow: hidden;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s ease;
  }

  .sol-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .sol-card-visual {
    height: 200px;
    background: transparent;
    border-radius: 10px;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .sol-card-visual img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .sol-card:hover .sol-card-visual img {
    transform: scale(1.05);
  }

  .sol-card h3 {
    color: #0F2E65;
    margin-bottom: 1rem;
    font-size: 1.2rem;
  }

  .sol-card p {
    font-size: 0.85rem;
    color: #4a5568;
    margin-bottom: 2rem;
  }

  .ver-mas {
    color: #78BE20;
    font-weight: 700;
    font-size: 0.85rem;
  }

  .contact-cta-card {
    background: #0F2E65;
    color: white;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .contact-cta-card h3 {
    color: white;
    font-size: 1.4rem;
  }

  .contact-cta-icon {
    font-size: 3rem;
  }

  .cta-btns {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    width: 100%;
  }

  .btn-white {
    background: white;
    color: #0F2E65;
    padding: 0.8rem;
    border-radius: 50px;
    font-weight: 700;
  }

  .btn-outline-white {
    border: 1px solid white;
    color: white;
    padding: 0.8rem;
    border-radius: 50px;
    font-weight: 700;
  }

  .section-title-center {
    text-align: center;
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    color: #0F2E65;
    margin-bottom: 4rem;
  }

  .section-title-center.small {
    font-size: 1.5rem;
    margin-bottom: 3rem;
  }

  .success-cases {
    padding: 6rem 0;
    background: linear-gradient(180deg, #ffffff 0%, #f4f7fb 100%);
  }

  /* Casos de éxito - grid de tarjetas expandibles */
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.5rem;
  }

  /* 3 por fila (cada tarjeta abarca 2 de 6 columnas); las dos últimas se centran */
  .case-tile {
    grid-column: span 2;
  }

  .case-tile:nth-child(4) {
    grid-column: 2 / span 2;
  }

  .case-tile:nth-child(5) {
    grid-column: 4 / span 2;
  }

  .case-tile {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    background: #0F2E65;
    box-shadow: 0 10px 28px rgba(15, 46, 101, 0.12);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    isolation: isolate;
  }

  .case-tile:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(15, 46, 101, 0.22);
  }

  .case-tile:focus-visible {
    outline: 3px solid #78BE20;
    outline-offset: 3px;
  }

  .case-tile-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .case-tile:hover .case-tile-img,
  .case-tile.is-open .case-tile-img {
    transform: scale(1.06);
    will-change: transform;
  }

  .case-tile-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to top, rgba(10, 18, 40, 0.92) 0%, rgba(10, 18, 40, 0.45) 40%, rgba(10, 18, 40, 0) 70%);
  }

  .case-tile-tag {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 3;
    background: rgba(120, 190, 32, 0.95);
    color: #0F2E65;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }

  .case-tile-head {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 1.5rem 1.4rem;
    transition: opacity 0.3s ease;
  }

  .case-tile:hover .case-tile-head,
  .case-tile.is-open .case-tile-head {
    opacity: 0;
  }

  .case-tile-cat {
    display: block;
    color: #78BE20;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }

  .case-tile-title {
    color: #ffffff;
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 0.5rem;
  }

  .case-tile-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: #78BE20;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .case-tile-icon {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  /* Panel de detalle deslizante */
  .case-tile-detail {
    position: absolute;
    inset: 0;
    z-index: 4;
    background: linear-gradient(160deg, rgba(15, 46, 101, 0.97), rgba(10, 24, 60, 0.98));
    padding: 1.6rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transform: translateY(100%);
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    overflow-y: auto;
    will-change: transform;
    backface-visibility: hidden;
  }

  .case-tile:hover .case-tile-detail,
  .case-tile:focus-within .case-tile-detail,
  .case-tile.is-open .case-tile-detail {
    transform: translateY(0);
  }

  .case-tile.is-open .case-tile-icon {
    transform: rotate(45deg);
  }

  .case-tile-detail .case-detail-eyebrow {
    display: block;
    color: #78BE20;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .case-tile-detail h3 {
    color: #ffffff;
    font-size: 1.15rem;
    line-height: 1.3;
    margin: 0 0 1rem;
  }

  .case-tile-desc {
    margin: 0;
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .cases-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .case-tile:nth-child(4) {
      grid-column: span 2;
    }
    .case-tile:nth-child(5) {
      grid-column: 2 / span 2;
    }
  }

  @media (max-width: 560px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
    .case-tile,
    .case-tile:nth-child(4),
    .case-tile:nth-child(5) {
      grid-column: auto;
    }
    .case-tile {
      aspect-ratio: 16 / 11;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .case-tile,
    .case-tile-img,
    .case-tile-detail,
    .case-tile-head,
    .case-tile-icon {
      transition: none !important;
    }
  }

  .diferenciadores-section {
    padding: 6rem 0;
    background: linear-gradient(180deg, #f4f7fb 0%, #ffffff 100%);
  }

  .dif-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .dif-eyebrow {
    color: #78BE20;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }

  .dif-header h2 {
    color: #0F2E65;
    font-size: clamp(1.8rem, 5vw, 2.5rem);
    font-weight: 700;
    margin: 0;
  }

  .dif-underline {
    display: block;
    width: 56px;
    height: 4px;
    border-radius: 999px;
    background: #78BE20;
    margin: 1rem auto 0;
  }

  .diferenciadores-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .dif-card {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: #ffffff;
    border: 1px solid #e6e9f2;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 6px 20px rgba(15, 46, 101, 0.05);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .dif-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: #78BE20;
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.3s ease;
  }

  .dif-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 34px rgba(15, 46, 101, 0.12);
    border-color: #cfe0b3;
  }

  .dif-card:hover::before {
    transform: scaleY(1);
  }

  .dif-icon {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(120, 190, 32, 0.16), rgba(120, 190, 32, 0.04));
    color: #5a9410;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .dif-icon :global(svg) {
    width: 1.5rem;
    height: 1.5rem;
  }

  .dif-card:hover .dif-icon {
    background: #78BE20;
    color: #ffffff;
  }

  .dif-card p {
    margin: 0;
    color: #0F2E65;
    font-size: 0.98rem;
    font-weight: 600;
    line-height: 1.45;
  }

  @media (max-width: 900px) {
    .diferenciadores-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .diferenciadores-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dif-card,
    .dif-card::before,
    .dif-icon {
      transition: none !important;
    }
  }

  @media (max-width: 992px) {
    .solutions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
