---
import Layout from '../../layouts/Layout.astro';
import Partners from '../../components/home/Partners.astro';

const especialidades = [
  'Diseño e implementación de redes, videovigilancia y redes de fibra óptica, microondas y datacenter.',
  'Ciberseguridad y contrainteligencia',
  'Construcción y Mantenimiento de Centros de comando (C5, C4 y C2).',
  'Radiocomunicación policial y accesorios de monitoreo personal.',
  'Pólizas de mantenimiento preventivo y correctivo de redes, enlaces y videovigilancia.'
];
---

<Layout title="¿Quiénes Somos? - Luminet">
  <section class="quienes-hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <span class="hero-eyebrow">LUMINET GOBIERNO</span>
      <h1>¿Quienes somos?</h1>
      <div class="title-underline"></div>
      <p class="hero-subtitle">
        Conectividad inteligente para el sector público en México
      </p>

      <div class="intro-cards">
        <div class="intro-card">
          <p>
            En <strong>Luminet Gobierno</strong> nos especializamos en el <strong>sector público</strong>, ofreciendo soluciones integrales de conectividad e infraestructura TI para dependencias, secretarías, municipios y organismos gubernamentales. Somos <strong>Concesionarios Federales de Comunicaciones, regulados por el IFT</strong>, con <u>operaciones en toda la República Mexicana</u>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="quienes-ops">
    <div class="container">
      <div class="ops-section-header">
        <span class="ops-eyebrow">NUESTRA PRESENCIA</span>
        <h2>Cobertura y especialidades</h2>
        <p>Operamos a nivel nacional con soluciones especializadas para el sector público.</p>
      </div>

      <div class="ops-card map-card">
        <div class="ops-card-header">
          <h3>Operaciones a nivel nacional</h3>
          <span class="ops-pill">México</span>
        </div>

        <div class="map-stage">
          <img class="map-image" src="/mexico-mapa.svg" alt="Mapa de México con presencia de Luminet a nivel nacional" loading="lazy" decoding="async" />
        </div>

        <div class="map-footer">
          <div class="ift-badge">
            <div class="ift-badge-text">
              <strong>Empresa regulada y</strong>
              <span>concesionada por el IFT</span>
            </div>
            <img class="ift-logo" src="/ift.webp" alt="Instituto Federal de Telecomunicaciones" width="120" height="120" loading="lazy" decoding="async" />
          </div>
          <div class="ift-stats">
            <strong>32</strong>
            <span>estados con cobertura</span>
          </div>
        </div>
      </div>

      <div class="ops-card esp-card">
        <div class="ops-card-header">
          <h3>Especialidades</h3>
          <span class="ops-pill green">5 áreas clave</span>
        </div>

        <div class="esp-carousel" data-esp-carousel>
          <div class="esp-slides">
            {especialidades.map((item, i) => (
              <article class={`esp-slide${i === 0 ? ' is-active' : ''}`} data-esp-slide={i}>
                <span class="esp-num">{String(i + 1).padStart(2, '0')}</span>
                <p class="esp-text">{item}</p>
              </article>
            ))}
          </div>

          <div class="esp-controls">
            <button class="esp-arrow" data-esp-prev type="button" aria-label="Especialidad anterior">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>

            <div class="esp-dots">
              {especialidades.map((_, i) => (
                <button class={`esp-dot${i === 0 ? ' is-active' : ''}`} data-esp-dot={i} type="button" aria-label={`Ver especialidad ${i + 1}`}></button>
              ))}
            </div>

            <button class="esp-arrow" data-esp-next type="button" aria-label="Siguiente especialidad">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mv-section">
    <div class="container">
      <div class="ops-section-header">
        <span class="ops-eyebrow">NUESTRO PROPÓSITO</span>
        <h2>Misión y Visión</h2>
        <p>Lo que nos mueve y hacia dónde vamos como aliado tecnológico del sector público.</p>
      </div>

      <div class="mv-grid">
        <article class="mv-item">
          <h3>Misión</h3>
          <span class="mv-line"></span>
          <p>
            Proporcionar soluciones de conectividad e infraestructura TI de grado institucional
            que garanticen la continuidad operativa y la transformación digital de las dependencias
            de gobierno en México, con los más altos estándares de calidad, seguridad y cumplimiento normativo.
          </p>
        </article>

        <article class="mv-item">
          <h3>Visión</h3>
          <span class="mv-line"></span>
          <p>
            Ser el aliado tecnológico de referencia del sector público mexicano, reconocido por
            impulsar instituciones más conectadas, seguras y eficientes al servicio de la ciudadanía.
          </p>
        </article>
      </div>
    </div>
  </section>

  <Partners />
</Layout>

<script>
  function initEspCarousel() {
    const carousel = document.querySelector('[data-esp-carousel]');
    if (!carousel) return;

    const slides = Array.from(carousel.querySelectorAll('[data-esp-slide]'));
    const dots = Array.from(carousel.querySelectorAll('[data-esp-dot]'));
    const prevBtn = carousel.querySelector('[data-esp-prev]');
    const nextBtn = carousel.querySelector('[data-esp-next]');
    if (slides.length === 0) return;

    let current = 0;
    let timer = 0;
    const INTERVAL = 5000;

    function show(index: number) {
      current = (index + slides.length) % slides.length;
      slides.forEach((s, i) => s.classList.toggle('is-active', i === current));
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    }

    function next() { show(current + 1); }
    function prev() { show(current - 1); }

    function start() {
      stop();
      timer = window.setInterval(next, INTERVAL);
    }
    function stop() {
      if (timer) window.clearInterval(timer);
    }
    function restart() { start(); }

    nextBtn?.addEventListener('click', () => { next(); restart(); });
    prevBtn?.addEventListener('click', () => { prev(); restart(); });
    dots.forEach((dot, i) => dot.addEventListener('click', () => { show(i); restart(); }));

    carousel.addEventListener('mouseenter', stop);
    carousel.addEventListener('mouseleave', start);

    show(0);
    start();
  }

  initEspCarousel();
  document.addEventListener('astro:page-load', initEspCarousel);
</script>

<style is:global>
  .quienes-hero .container,
  .quienes-ops .container,
  .mv-section .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .quienes-hero {
    position: relative;
    background: url('/internet-hero.webp') center/cover no-repeat;
    color: white;
    padding: calc(80px + 5rem) 0 6rem;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 10%, rgba(43, 89, 255, 0.18), transparent 55%),
      radial-gradient(ellipse at 80% 90%, rgba(164, 210, 51, 0.12), transparent 55%),
      linear-gradient(180deg, rgba(0, 8, 41, 0.65), rgba(0, 8, 41, 0.92));
    z-index: -1;
  }

  .hero-content {
    text-align: center;
    max-width: 1100px;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 4px;
    color: #a4d233;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    padding: 0.4rem 1rem;
    border: 1px solid rgba(164, 210, 51, 0.4);
    border-radius: 999px;
    background: rgba(164, 210, 51, 0.08);
  }

  .quienes-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .title-underline {
    width: 120px;
    height: 4px;
    background: #a4d233;
    margin: 1.5rem auto 1.5rem;
    border-radius: 2px;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.78);
    max-width: 640px;
    margin: 0 auto 3.5rem;
    line-height: 1.6;
  }

  .intro-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    text-align: left;
    margin-top: 1rem;
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }

  .intro-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    padding: 2rem 2.25rem;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .intro-card:hover {
    border-color: rgba(164, 210, 51, 0.4);
    transform: translateY(-4px);
  }

  .intro-card p {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  .intro-card strong {
    color: #fff;
    font-weight: 700;
  }

  .intro-card u {
    text-decoration-color: #a4d233;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }

  @media (max-width: 768px) {
    .intro-cards {
      grid-template-columns: 1fr;
    }
    .quienes-hero {
      padding: 6rem 0 4rem;
    }
  }

  .quienes-ops {
    background: linear-gradient(180deg, #f5f7fb 0%, #ffffff 100%);
    color: #1a202c;
    padding: 6rem 0 8rem;
  }

  .ops-section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 4rem;
  }

  .ops-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 3px;
    color: #2b59ff;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .ops-section-header h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    color: #000bb3;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .ops-section-header p {
    color: #5a6478;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  .ops-card {
    background: #ffffff;
    border: 1px solid #e6e9f2;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 4px 24px rgba(15, 23, 42, 0.04);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .map-card {
    margin-bottom: 2rem;
  }

  .ops-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(15, 23, 42, 0.08);
  }

  .ops-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .ops-card-header h3 {
    font-size: 1.25rem;
    color: #000bb3;
    margin: 0;
    font-weight: 700;
  }

  .ops-pill {
    background: rgba(15, 46, 101, 0.08);
    color: #0F2E65;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
  }

  .ops-pill.green {
    background: rgba(120, 190, 32, 0.15);
    color: #5a8f18;
  }

  /* MAP CARD */
  .map-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 420px;
    background:
      radial-gradient(circle at 50% 45%, rgba(15, 46, 101, 0.08), transparent 60%),
      linear-gradient(160deg, #ffffff 0%, #eef2fb 55%, #e3eaf8 100%);
    background-color: #f4f7fd;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 1.75rem;
    box-shadow: inset 0 0 0 1px rgba(15, 46, 101, 0.12);
  }

  .map-stage::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(15, 46, 101, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 46, 101, 0.05) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse at center, black 35%, transparent 78%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 35%, transparent 78%);
    pointer-events: none;
  }

  .map-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    object-fit: contain;
    object-position: center;
    z-index: 1;
    pointer-events: none;
    padding: 1.5rem;
    filter: drop-shadow(0 18px 32px rgba(15, 46, 101, 0.30));
  }

  .map-glow {
    position: absolute;
    width: 60%;
    height: 60%;
    background: radial-gradient(circle, rgba(164, 210, 51, 0.18), transparent 70%);
    top: 20%;
    left: 20%;
    filter: blur(40px);
  }

  .map-grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
  }

  .map-pin {
    position: absolute;
    width: 12px;
    height: 12px;
    background: #a4d233;
    border-radius: 50%;
    box-shadow:
      0 0 0 5px rgba(164, 210, 51, 0.22),
      0 0 18px rgba(164, 210, 51, 0.7);
    animation: mp-pulse 2.4s ease-in-out infinite;
  }

  .pin-1 { top: 26%; left: 20%; }
  .pin-2 { top: 36%; left: 38%; animation-delay: 0.3s; }
  .pin-3 { top: 50%; left: 28%; animation-delay: 0.6s; }
  .pin-4 { top: 45%; left: 58%; animation-delay: 0.9s; }
  .pin-5 { top: 62%; left: 48%; animation-delay: 1.2s; }
  .pin-6 { top: 32%; left: 72%; animation-delay: 1.5s; }
  .pin-7 { top: 58%; left: 78%; animation-delay: 1.8s; }

  @keyframes mp-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.35); opacity: 0.65; }
  }

  .map-footer {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 1rem;
  }

  .ift-badge {
    background: #f5f7fb;
    border: 1px solid #e6e9f2;
    border-radius: 12px;
    padding: 0.85rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    color: #2b59ff;
  }

  .ift-badge-text {
    text-align: left;
  }

  .ift-badge strong {
    display: block;
    font-size: 0.9rem;
    color: #000bb3;
    line-height: 1.3;
  }

  .ift-badge span {
    display: block;
    font-size: 0.78rem;
    color: #5a6478;
  }

  .ift-logo {
    width: 84px;
    height: auto;
    object-fit: contain;
    flex-shrink: 0;
  }

  .ift-stats {
    background: linear-gradient(135deg, #0F2E65 0%, #1a4a8f 100%);
    color: white;
    border-radius: 12px;
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;
  }

  .ift-stats strong {
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1;
  }

  .ift-stats span {
    font-size: 0.72rem;
    opacity: 0.85;
    margin-top: 0.25rem;
  }

  /* ESPECIALIDADES CARROUSEL */
  .esp-carousel {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .esp-slides {
    position: relative;
    display: grid;
    min-height: 200px;
    border-radius: 16px;
    background:
      radial-gradient(circle at 12% 20%, rgba(120, 190, 32, 0.12), transparent 55%),
      linear-gradient(135deg, #f5f7fb 0%, #ffffff 100%);
    border: 1px solid #e6e9f2;
    overflow: hidden;
  }

  .esp-slide {
    grid-area: 1 / 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 2.5rem 2.75rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(14px);
    transition: opacity 0.5s ease, transform 0.5s ease, visibility 0.5s;
    pointer-events: none;
  }

  .esp-slide.is-active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .esp-num {
    font-size: clamp(2.75rem, 6vw, 4rem);
    font-weight: 800;
    color: #78BE20;
    line-height: 0.9;
    letter-spacing: -0.02em;
  }

  .esp-text {
    color: #1a202c;
    font-size: clamp(1.05rem, 2vw, 1.4rem);
    font-weight: 600;
    line-height: 1.5;
    margin: 0;
    max-width: 720px;
  }

  .esp-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
  }

  .esp-arrow {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid #e6e9f2;
    background: #ffffff;
    color: #0F2E65;
    cursor: pointer;
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
  }

  .esp-arrow:hover {
    background: #0F2E65;
    border-color: #0F2E65;
    color: #ffffff;
    transform: scale(1.08);
  }

  .esp-dots {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .esp-dot {
    width: 10px;
    height: 10px;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: #cdd5e6;
    cursor: pointer;
    transition: width 0.3s ease, background 0.3s ease;
  }

  .esp-dot.is-active {
    width: 30px;
    background: #78BE20;
  }

  @media (max-width: 900px) {
    .map-footer {
      grid-template-columns: 1fr;
    }
    .map-stage {
      min-height: 300px;
    }
    .esp-slide {
      padding: 2rem 1.5rem;
    }
  }

  /* Misión y Visión — minimalista */
  .mv-section {
    padding: clamp(3rem, 7vw, 6rem) 0;
    background: #fff;
  }
  .mv-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(2.5rem, 5vw, 4.5rem);
    max-width: 1000px;
    margin: 0 auto;
  }
  .mv-section .ops-section-header {
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }
  .mv-item h3 {
    font-size: clamp(1.6rem, 3vw, 2rem);
    font-weight: 700;
    color: #0F2E65;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .mv-line {
    display: block;
    width: 48px;
    height: 4px;
    border-radius: 4px;
    background: #78BE20;
    margin-bottom: 1.5rem;
  }
  .mv-item p {
    font-size: 1.05rem;
    line-height: 1.85;
    color: #56637a;
  }
  @media (max-width: 768px) {
    .mv-grid { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>
