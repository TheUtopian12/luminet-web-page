---
import Layout from '../../layouts/Layout.astro';
import Partners from '../../components/home/Partners.astro';

const especialidades = [
  'Diseño e implementación de redes, videovigilancia y redes de fibra óptica, microondas y datacenter.',
  'Ciberseguridad y contrainteligencia',
  'Construcción y Mantenimiento de Centros de comando (C5, C4 y C2).',
  'Radiocomunicación policial y accesorios de monitoreo personal.',
  'Pólizas de mantenimiento preventivo y correctivo de redes, enlaces y videovigilancia.'
];
---

<Layout title="¿Quiénes Somos? - Luminet">
  <section class="quienes-hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <span class="hero-eyebrow">LUMINET GOBIERNO</span>
      <h1>¿Quienes somos?</h1>
      <div class="title-underline"></div>
      <p class="hero-subtitle">
        Conectividad inteligente para el sector público en México
      </p>

      <div class="intro-cards">
        <div class="intro-card">
          <p>
            En <strong>LUMINET GOBIERNO</strong> nos enfocamos en el <strong>sector público</strong>, ofreciendo soluciones integrales para mejorar la conectividad de las instalaciones gubernamentales, consolidándonos así como una empresa <strong>TechCo</strong> referente.
          </p>
        </div>
        <div class="intro-card">
          <p>
            Aprovechamos el potencial de la <u>conectividad inteligente</u> para diseñar y desarrollar ecosistemas digitales que combinan software, infraestructura y servicios especializados, orientados a resolver problemas complejos y maximizar la eficiencia operativa.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="quienes-ops">
    <div class="container ops-grid">
      <div class="ops-left">
        <h3 class="ops-title">Operaciones a nivel nacional</h3>
        <div class="map-placeholder">
          <div class="map-tag">Concesionarios Federales de Comunicaciones</div>
        </div>
        <div class="ift-block">
          <p class="ift-text">Empresa regulada y concesionada por el IFT</p>
        </div>
      </div>

      <div class="ops-right">
        <h3 class="esp-title">Especialidades</h3>
        <div class="esp-divider"></div>
        <ul class="esp-list">
          {especialidades.map((item, i) => (
            <li>
              <span class="esp-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="esp-text">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <Partners />
</Layout>

<style is:global>
  .quienes-hero {
    position: relative;
    background: url('/internet-hero.png') center/cover no-repeat;
    color: white;
    padding: calc(80px + 5rem) 0 6rem;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 10%, rgba(43, 89, 255, 0.18), transparent 55%),
      radial-gradient(ellipse at 80% 90%, rgba(164, 210, 51, 0.12), transparent 55%),
      linear-gradient(180deg, rgba(0, 8, 41, 0.65), rgba(0, 8, 41, 0.92));
    z-index: -1;
  }

  .hero-content {
    text-align: center;
    max-width: 1100px;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 4px;
    color: #a4d233;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    padding: 0.4rem 1rem;
    border: 1px solid rgba(164, 210, 51, 0.4);
    border-radius: 999px;
    background: rgba(164, 210, 51, 0.08);
  }

  .quienes-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .title-underline {
    width: 120px;
    height: 4px;
    background: #a4d233;
    margin: 1.5rem auto 1.5rem;
    border-radius: 2px;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.78);
    max-width: 640px;
    margin: 0 auto 3.5rem;
    line-height: 1.6;
  }

  .intro-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    text-align: left;
    margin-top: 1rem;
  }

  .intro-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    padding: 2rem 2.25rem;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .intro-card:hover {
    border-color: rgba(164, 210, 51, 0.4);
    transform: translateY(-4px);
  }

  .intro-card p {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  .intro-card strong {
    color: #fff;
    font-weight: 700;
  }

  .intro-card u {
    text-decoration-color: #a4d233;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }

  @media (max-width: 768px) {
    .intro-cards {
      grid-template-columns: 1fr;
    }
    .quienes-hero {
      padding: 6rem 0 4rem;
    }
  }

  .quienes-ops {
    background: #ffffff;
    color: #1a202c;
    padding: 6rem 0;
  }

  .ops-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .ops-title,
  .esp-title {
    font-size: 1.5rem;
    color: #000bb3;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .map-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, #0a2a6b 0%, #1740a8 100%);
    border-radius: 12px;
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 1.5rem;
  }

  .map-tag {
    background: #000829;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    font-size: 0.8rem;
    text-align: center;
    max-width: 220px;
  }

  .ift-block {
    margin-top: 1.5rem;
    text-align: center;
  }

  .ift-text {
    color: #4a5568;
    font-size: 0.9rem;
  }

  .esp-divider {
    width: 180px;
    height: 3px;
    background: #a4d233;
    margin: 0 auto 2rem;
    border-radius: 2px;
  }

  .esp-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .esp-list li {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1rem;
    align-items: start;
  }

  .esp-num {
    font-size: 1.8rem;
    font-weight: 700;
    color: #a4d233;
    line-height: 1;
  }

  .esp-text {
    color: #2d3748;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .ops-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
