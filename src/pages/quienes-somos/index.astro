---
import Layout from '../../layouts/Layout.astro';
import Partners from '../../components/home/Partners.astro';

const especialidades = [
  'Diseño e implementación de redes, videovigilancia y redes de fibra óptica, microondas y datacenter.',
  'Ciberseguridad y contrainteligencia',
  'Construcción y Mantenimiento de Centros de comando (C5, C4 y C2).',
  'Radiocomunicación policial y accesorios de monitoreo personal.',
  'Pólizas de mantenimiento preventivo y correctivo de redes, enlaces y videovigilancia.'
];
---

<Layout title="¿Quiénes Somos? - Luminet">
  <section class="quienes-hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <span class="hero-eyebrow">LUMINET GOBIERNO</span>
      <h1>¿Quienes somos?</h1>
      <div class="title-underline"></div>
      <p class="hero-subtitle">
        Conectividad inteligente para el sector público en México
      </p>

      <div class="intro-cards">
        <div class="intro-card">
          <p>
            En <strong>LUMINET GOBIERNO</strong> nos enfocamos en el <strong>sector público</strong>, ofreciendo soluciones integrales para mejorar la conectividad de las instalaciones gubernamentales, consolidándonos así como una empresa <strong>TechCo</strong> referente.
          </p>
        </div>
        <div class="intro-card">
          <p>
            Aprovechamos el potencial de la <u>conectividad inteligente</u> para diseñar y desarrollar ecosistemas digitales que combinan software, infraestructura y servicios especializados, orientados a resolver problemas complejos y maximizar la eficiencia operativa.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="quienes-ops">
    <div class="container">
      <div class="ops-section-header">
        <span class="ops-eyebrow">NUESTRA PRESENCIA</span>
        <h2>Cobertura y especialidades</h2>
        <p>Operamos a nivel nacional con soluciones especializadas para el sector público.</p>
      </div>

      <div class="ops-grid">
        <div class="ops-card map-card">
          <div class="ops-card-header">
            <h3>Operaciones a nivel nacional</h3>
            <span class="ops-pill">México</span>
          </div>

          <div class="map-stage">
            <img class="map-image" src="/mapa.webp" alt="Mapa de México con presencia de Luminet a nivel nacional" loading="lazy" decoding="async" />
            <div class="map-tag">
              <span class="map-tag-dot"></span>
              Concesionarios Federales de Comunicaciones
            </div>
          </div>

          <div class="map-footer">
            <div class="ift-badge">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <div>
                <strong>Empresa regulada</strong>
                <span>Concesionada por el IFT</span>
              </div>
            </div>
            <div class="ift-stats">
              <strong>32</strong>
              <span>estados con cobertura</span>
            </div>
          </div>
        </div>

        <div class="ops-card esp-card">
          <div class="ops-card-header">
            <h3>Especialidades</h3>
            <span class="ops-pill green">5 áreas clave</span>
          </div>

          <ul class="esp-list">
            {especialidades.map((item, i) => (
              <li class="esp-item">
                <span class="esp-num">{String(i + 1).padStart(2, '0')}</span>
                <p class="esp-text">{item}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <Partners />
</Layout>

<style is:global>
  .quienes-hero .container,
  .quienes-ops .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .quienes-hero {
    position: relative;
    background: url('/internet-hero.png') center/cover no-repeat;
    color: white;
    padding: calc(80px + 5rem) 0 6rem;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 10%, rgba(43, 89, 255, 0.18), transparent 55%),
      radial-gradient(ellipse at 80% 90%, rgba(164, 210, 51, 0.12), transparent 55%),
      linear-gradient(180deg, rgba(0, 8, 41, 0.65), rgba(0, 8, 41, 0.92));
    z-index: -1;
  }

  .hero-content {
    text-align: center;
    max-width: 1100px;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 4px;
    color: #a4d233;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    padding: 0.4rem 1rem;
    border: 1px solid rgba(164, 210, 51, 0.4);
    border-radius: 999px;
    background: rgba(164, 210, 51, 0.08);
  }

  .quienes-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .title-underline {
    width: 120px;
    height: 4px;
    background: #a4d233;
    margin: 1.5rem auto 1.5rem;
    border-radius: 2px;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.78);
    max-width: 640px;
    margin: 0 auto 3.5rem;
    line-height: 1.6;
  }

  .intro-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    text-align: left;
    margin-top: 1rem;
  }

  .intro-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    padding: 2rem 2.25rem;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .intro-card:hover {
    border-color: rgba(164, 210, 51, 0.4);
    transform: translateY(-4px);
  }

  .intro-card p {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  .intro-card strong {
    color: #fff;
    font-weight: 700;
  }

  .intro-card u {
    text-decoration-color: #a4d233;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }

  @media (max-width: 768px) {
    .intro-cards {
      grid-template-columns: 1fr;
    }
    .quienes-hero {
      padding: 6rem 0 4rem;
    }
  }

  .quienes-ops {
    background: linear-gradient(180deg, #f5f7fb 0%, #ffffff 100%);
    color: #1a202c;
    padding: 6rem 0 8rem;
  }

  .ops-section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 4rem;
  }

  .ops-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 3px;
    color: #2b59ff;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .ops-section-header h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    color: #000bb3;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .ops-section-header p {
    color: #5a6478;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  .ops-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 2rem;
    align-items: stretch;
  }

  .ops-card {
    background: #ffffff;
    border: 1px solid #e6e9f2;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 4px 24px rgba(15, 23, 42, 0.04);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ops-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(15, 23, 42, 0.08);
  }

  .ops-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .ops-card-header h3 {
    font-size: 1.25rem;
    color: #000bb3;
    margin: 0;
    font-weight: 700;
  }

  .ops-pill {
    background: rgba(43, 89, 255, 0.08);
    color: #2b59ff;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
  }

  .ops-pill.green {
    background: rgba(164, 210, 51, 0.15);
    color: #6b9410;
  }

  /* MAP CARD */
  .map-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 11;
    background:
      radial-gradient(circle at 50% 55%, rgba(43, 89, 255, 0.35), transparent 60%),
      linear-gradient(135deg, #0a1f5c 0%, #00104a 50%, #0a2a6b 100%);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 1.25rem;
  }

  .map-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    object-fit: contain;
    object-position: center;
    z-index: 1;
    pointer-events: none;
    image-rendering: auto;
    image-rendering: -webkit-optimize-contrast;
    filter: contrast(1.05) saturate(1.1);
  }

  .map-glow {
    position: absolute;
    width: 60%;
    height: 60%;
    background: radial-gradient(circle, rgba(164, 210, 51, 0.18), transparent 70%);
    top: 20%;
    left: 20%;
    filter: blur(40px);
  }

  .map-grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
  }

  .map-pin {
    position: absolute;
    width: 12px;
    height: 12px;
    background: #a4d233;
    border-radius: 50%;
    box-shadow:
      0 0 0 5px rgba(164, 210, 51, 0.22),
      0 0 18px rgba(164, 210, 51, 0.7);
    animation: mp-pulse 2.4s ease-in-out infinite;
  }

  .pin-1 { top: 26%; left: 20%; }
  .pin-2 { top: 36%; left: 38%; animation-delay: 0.3s; }
  .pin-3 { top: 50%; left: 28%; animation-delay: 0.6s; }
  .pin-4 { top: 45%; left: 58%; animation-delay: 0.9s; }
  .pin-5 { top: 62%; left: 48%; animation-delay: 1.2s; }
  .pin-6 { top: 32%; left: 72%; animation-delay: 1.5s; }
  .pin-7 { top: 58%; left: 78%; animation-delay: 1.8s; }

  @keyframes mp-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.35); opacity: 0.65; }
  }

  .map-tag {
    position: relative;
    z-index: 1;
    background: rgba(0, 8, 41, 0.85);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: white;
    padding: 0.6rem 1rem;
    border-radius: 10px;
    font-size: 0.78rem;
    font-weight: 500;
    text-align: center;
    max-width: 260px;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .map-tag-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #a4d233;
    box-shadow: 0 0 8px rgba(164, 210, 51, 0.8);
  }

  .map-footer {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 1rem;
  }

  .ift-badge {
    background: #f5f7fb;
    border: 1px solid #e6e9f2;
    border-radius: 12px;
    padding: 0.85rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #2b59ff;
  }

  .ift-badge strong {
    display: block;
    font-size: 0.9rem;
    color: #000bb3;
    line-height: 1.3;
  }

  .ift-badge span {
    display: block;
    font-size: 0.78rem;
    color: #5a6478;
  }

  .ift-stats {
    background: linear-gradient(135deg, #000bb3 0%, #2b59ff 100%);
    color: white;
    border-radius: 12px;
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;
  }

  .ift-stats strong {
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1;
  }

  .ift-stats span {
    font-size: 0.72rem;
    opacity: 0.85;
    margin-top: 0.25rem;
  }

  /* ESPECIALIDADES CARD */
  .esp-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .esp-item {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 1rem;
    align-items: center;
    padding: 0.9rem 1rem;
    border-radius: 12px;
    background: #f8f9fc;
    border: 1px solid transparent;
    transition: border-color 0.25s ease, background 0.25s ease, transform 0.25s ease;
  }

  .esp-item:hover {
    background: #ffffff;
    border-color: rgba(164, 210, 51, 0.5);
    transform: translateX(4px);
  }

  .esp-num {
    font-size: 1.4rem;
    font-weight: 800;
    color: #a4d233;
    line-height: 1;
    text-align: center;
  }

  .esp-text {
    color: #2d3748;
    font-size: 0.92rem;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 900px) {
    .ops-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .map-footer {
      grid-template-columns: 1fr;
    }
  }
</style>
