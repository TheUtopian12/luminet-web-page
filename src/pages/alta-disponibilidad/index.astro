---
import Layout from "../../layouts/Layout.astro";
import { 
  Wifi, 
  Shield, 
  Server, 
  Clock, 
  Zap, 
  Headphones, 
  Laptop, 
  FileText, 
  Phone,
  MessageCircle,
  Mail,
  Globe,
  ArrowRight, 
  ChevronRight, 
  HelpCircle, 
  Sparkles, 
  Send, 
  CheckCircle, 
  ArrowUpRight
} from "lucide-astro";

const title = "Alta Disponibilidad";
const badge = "Infraestructura Cloud";
const subtitle = "Mantén tus aplicaciones críticas siempre operativas con nuestra infraestructura redundante, enlaces blindados y monitoreo activo en Data Centers.";
const bgImage = "https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=1920&h=1080&fit=crop";

const highlights = [
  {icon: Wifi, title: "Enlaces redundantes multirruta"},
  {icon: Clock, title: "Disponibilidad del 99.999%"},
  {icon: Shield, title: "Detección proactiva de fallas"},
  {icon: Server, title: "Data Centers redundantes en México"}
];

const features = [
  {title: "Inspección Profunda", desc: "Visión de uso de servicio de Internet. Segmentación por categorías o páginas web.", icon: Server, color: "from-blue-500/20 to-blue-600/5"},
  {title: "Failover Automático", desc: "Cambio instantáneo de rutas de acceso de red ante fallas de canal físico.", icon: Zap, color: "from-luminet-lime/20 to-luminet-lime/5"},
  {title: "Soporte Certificado", desc: "Ingenieros de red vigilando y operando tu infraestructura las 24 horas.", icon: Headphones, color: "from-orange-500/20 to-orange-500/5"}
];

const cases = [
  {title: "Nombre de Marca 1", desc: "(Descripción del servicio realizado) Implementamos una solución de alta disponibilidad con 3 enlaces redundantes logrando 100% de operatividad anual.", tag: "Banca", image: "https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=800&h=500&fit=crop"},
  {title: "Nombre de Marca 2", desc: "(Descripción del servicio realizado) Respaldo híbrido satelital y de fibra óptica para servidores de bases de datos críticas.", tag: "Retail", image: "https://images.unsplash.com/photo-1563986768609-322da13575f2?w=800&h=500&fit=crop"}
];

const faqs = [
  {q: "¿En cuánto tiempo instalan?", a: "Instalamos en tiempo récord una vez contratado el servicio."},
  {q: "¿Ofrecen soporte 24/7?", a: "Sí, contamos con soporte técnico especializado disponible las 24 horas, los 365 días del año."},
  {q: "¿Pueden proteger múltiples sucursales?", a: "Sí, nuestras soluciones de ciberseguridad pueden escalar para proteger toda tu red empresarial."},
  {q: "¿Cómo empezaron?", a: "Luminet nació de la necesidad de ofrecer conectividad empresarial de clase mundial con un enfoque humano y técnico superior."}
];

const iconMap = {
  Wifi,
  Shield,
  Server,
  Clock,
  Zap,
  Headphones,
  Laptop,
  FileText,
  Phone,
  MessageCircle,
  Mail,
  Globe,
  ArrowUpRight
};
---

<Layout title={title + " - Luminet"}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-luminet-dark">
    <div class="absolute inset-0">
      <div 
        class="absolute inset-0 bg-cover bg-center opacity-40 mix-blend-luminosity" 
        style={`background-image: url("${bgImage}");`}
      ></div>
      <div class="absolute inset-0 bg-gradient-to-br from-luminet-navy/95 via-luminet-navy/85 to-luminet-navy-dark/95"></div>
      <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-luminet-lime/10 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 left-1/3 w-64 h-64 bg-luminet-lime/5 rounded-full blur-2xl animate-pulse" style="animation-delay: 1s;"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-28 pb-24 md:pt-36 md:pb-32">
      <!-- Breadcrumbs -->
      <nav class="flex items-center gap-2 text-sm text-white/50 mb-8 animate-fade-in">
        <a href="/" class="hover:text-luminet-lime transition-colors">Inicio</a>
        <ChevronRight class="w-4 h-4" />
        <a href="/conectividad" class="hover:text-luminet-lime transition-colors">Soluciones</a>
        <ChevronRight class="w-4 h-4" />
        <span class="text-luminet-lime">{title}</span>
      </nav>

      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-1.5 text-luminet-lime text-xs font-bold tracking-[0.2em] uppercase mb-4 px-3 py-1 rounded-full bg-luminet-lime/10 border border-luminet-lime/20">
          <Sparkles class="w-3.5 h-3.5" /> {badge}
        </span>
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.1] mb-5 tracking-tight animate-fade-in">
          {title}
        </h1>
        <p class="text-lg md:text-xl text-white/70 leading-relaxed max-w-2xl mb-8 animate-fade-in">
          {subtitle}
        </p>
        
        <div class="flex flex-wrap gap-4">
          <a href="#quote-form" class="inline-flex items-center gap-2 px-8 py-4 bg-luminet-lime text-luminet-navy font-bold rounded-full hover:bg-luminet-lime-light hover:scale-105 transition-all duration-300 shadow-lg shadow-luminet-lime/20">
            Cotizar solución
            <ArrowRight class="w-4 h-4" />
          </a>
          <a href="#features" class="inline-flex items-center gap-2 px-8 py-4 border border-white/20 hover:border-white/40 text-white font-semibold rounded-full hover:bg-white/5 transition-all duration-300">
            Diferenciadores clave
          </a>
        </div>
      </div>

      <!-- Highlights Horizontal List -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-16">
        {highlights.map((hl) => {
          const IconComponent = iconMap[hl.icon] || Wifi;
          return (
            <div class="px-6 py-5 bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl flex items-center gap-4 hover:border-luminet-lime/30 transition-all duration-300">
              <div class="w-10 h-10 rounded-xl bg-luminet-lime/10 flex items-center justify-center shrink-0 border border-luminet-lime/20">
                <IconComponent class="w-5 h-5 text-luminet-lime" />
              </div>
              <div class="text-sm font-bold text-white leading-snug">{hl.title}</div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Bottom curve -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-10 md:h-20" preserveAspectRatio="none">
        <path d="M0 120V60C240 0 480 0 720 30C960 60 1200 90 1440 60V120H0Z" fill="white"></path>
      </svg>
    </div>
  </section>

  <!-- Features/Diferenciadores Section -->
  <section id="features" class="py-20 md:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-luminet-lime/10 text-luminet-lime text-xs font-bold tracking-wider uppercase mb-3">
          <Shield class="w-3.5 h-3.5" /> Innovación y Respaldo
        </span>
        <h2 class="text-3xl md:text-5xl font-extrabold text-luminet-navy tracking-tight">
          Nuestros <span class="text-luminet-lime">Diferenciadores</span>
        </h2>
        <p class="text-gray-500 mt-4 text-lg max-w-2xl mx-auto leading-relaxed">
          Infraestructura de vanguardia y procesos diseñados específicamente para resolver los requerimientos de conectividad más exigentes del mercado.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {features.map((feat) => {
          const IconComponent = iconMap[feat.icon] || Shield;
          return (
            <div class="group relative p-8 rounded-3xl bg-luminet-gray border border-gray-100 shadow-card hover:shadow-card-hover hover:-translate-y-1.5 transition-all duration-500 overflow-hidden flex flex-col justify-between">
              <div class="absolute top-0 left-0 right-0 h-1 w-0 group-hover:w-full bg-gradient-to-r from-luminet-lime to-luminet-lime-light transition-all duration-500"></div>
              <div>
                <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${feat.color} flex items-center justify-center mb-6 border border-gray-100/50 group-hover:from-luminet-lime group-hover:to-luminet-lime-light transition-all duration-500`}>
                  <IconComponent class="w-6 h-6 text-luminet-navy group-hover:text-white transition-colors duration-500" />
                </div>
                <h3 class="text-xl font-bold text-luminet-navy mb-2 group-hover:text-luminet-lime transition-colors duration-300">
                  {feat.title}
                </h3>
                <p class="text-sm text-gray-500 leading-relaxed">
                  {feat.desc}
                </p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Success Cases Section -->
  <section class="py-20 md:py-28 bg-luminet-gray relative overflow-hidden">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-luminet-lime/10 text-luminet-lime text-xs font-bold tracking-wider uppercase mb-3">
          <Server class="w-3.5 h-3.5" /> Casos de Éxito
        </span>
        <h2 class="text-3xl md:text-5xl font-extrabold text-luminet-navy tracking-tight">
          Nuestros Clientes <span class="text-luminet-lime">Hablan por Nosotros</span>
        </h2>
        <p class="text-gray-500 mt-4 text-lg max-w-2xl mx-auto leading-relaxed">
          Casos reales de empresas líderes que han potenciado su productividad y asegurado su continuidad de red gracias a nuestras soluciones.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {cases.map((cs) => (
          <div class="group bg-white rounded-3xl overflow-hidden border border-gray-100 shadow-card hover:shadow-card-hover transition-all duration-500 flex flex-col sm:flex-row h-full">
            <div class="sm:w-1/2 relative h-48 sm:h-auto overflow-hidden">
              <img 
                src={cs.image} 
                alt={cs.title} 
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
              <span class="absolute top-4 left-4 px-3 py-1 text-xs font-bold text-luminet-navy bg-luminet-lime rounded-full uppercase tracking-wider">
                {cs.tag}
              </span>
            </div>
            <div class="sm:w-1/2 p-8 flex flex-col justify-between">
              <div>
                <h3 class="text-xl font-bold text-luminet-navy mb-3 group-hover:text-luminet-lime transition-colors">
                  {cs.title}
                </h3>
                <p class="text-sm text-gray-500 leading-relaxed">
                  {cs.desc}
                </p>
              </div>
              <div class="text-xs font-bold text-luminet-navy/40 uppercase tracking-widest mt-6">Caso de Éxito Certificado</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Interactive Lead Form / Quote Section -->
  <section id="quote-form" class="py-20 md:py-28 bg-white">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="bg-luminet-navy rounded-3xl p-8 md:p-12 relative overflow-hidden text-white shadow-card">
        <div class="absolute top-0 right-0 w-96 h-96 bg-luminet-lime/5 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 grid grid-cols-1 lg:grid-cols-5 gap-10 items-center">
          <div class="lg:col-span-2">
            <span class="inline-flex items-center gap-1 text-luminet-lime text-xs font-bold uppercase tracking-widest mb-3">
              <Sparkles class="w-3.5 h-3.5 animate-pulse" /> Cotización Rápida
            </span>
            <h2 class="text-3xl md:text-4xl font-extrabold text-white tracking-tight mb-4">
              Propuesta a <span class="text-luminet-lime">Tu Medida</span>
            </h2>
            <p class="text-white/70 text-base leading-relaxed mb-6">
              Analizamos los requerimientos particulares de tu empresa y diseñamos una solución tecnológica robusta y escalable sin costo alguno.
            </p>
            <div class="text-sm font-bold text-luminet-lime inline-block bg-luminet-lime/10 px-3 py-1.5 rounded-full border border-luminet-lime/20">
              Asesoría Gratuita &lt; 24 hrs
            </div>
          </div>

          <div class="lg:col-span-3 bg-white/5 backdrop-blur-md p-6 sm:p-8 rounded-2xl border border-white/10">
            <!-- Form Success Box -->
            <div id="quote-success" class="hidden text-center py-10 px-4 text-white">
              <div class="w-16 h-16 bg-luminet-lime/20 text-luminet-lime rounded-full flex items-center justify-center mx-auto mb-4 border border-luminet-lime/20 animate-bounce">
                <CheckCircle class="w-8 h-8" />
              </div>
              <h4 class="text-xl font-bold mb-2">¡Solicitud Enviada!</h4>
              <p class="text-white/70 text-sm max-w-sm mx-auto mb-4">
                Tu requerimiento de cotización ha sido registrado. Un consultor experto se comunicará contigo de inmediato.
              </p>
              <button id="reset-quote" class="text-xs font-bold text-luminet-lime hover:underline">Solicitar otra cotización</button>
            </div>

            <!-- Lead Form -->
            <form id="solution-quote-form" class="space-y-4">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-bold text-white/70 uppercase mb-1">Nombre completo <span class="text-red-500">*</span></label>
                  <input type="text" name="nombre" required class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 focus:border-luminet-lime focus:outline-none text-white text-sm transition-colors placeholder-white/30" placeholder="Tu nombre" />
                </div>
                <div>
                  <label class="block text-xs font-bold text-white/70 uppercase mb-1">Email corporativo <span class="text-red-500">*</span></label>
                  <input type="email" name="email" required class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 focus:border-luminet-lime focus:outline-none text-white text-sm transition-colors placeholder-white/30" placeholder="empresa@tu.com" />
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-bold text-white/70 uppercase mb-1">Teléfono corporativo <span class="text-red-500">*</span></label>
                  <input type="tel" name="telefono" required class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 focus:border-luminet-lime focus:outline-none text-white text-sm transition-colors placeholder-white/30" placeholder="10 dígitos" />
                </div>
                <div>
                  <label class="block text-xs font-bold text-white/70 uppercase mb-1">Compañía <span class="text-red-500">*</span></label>
                  <input type="text" name="compania" required class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 focus:border-luminet-lime focus:outline-none text-white text-sm transition-colors placeholder-white/30" placeholder="Nombre de tu empresa" />
                </div>
              </div>
              <div>
                <label class="block text-xs font-bold text-white/70 uppercase mb-1">Descripción de tu necesidad</label>
                <textarea name="mensaje" rows="2" class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/10 focus:border-luminet-lime focus:outline-none text-white text-sm transition-colors placeholder-white/30 resize-none" placeholder="Cuéntanos brevemente qué velocidad o solución requieres..."></textarea>
              </div>
              <input type="hidden" name="necesidad" value={title} />
              <button type="submit" class="w-full py-4 bg-luminet-lime text-luminet-navy hover:bg-luminet-lime-light font-extrabold rounded-xl transition-all duration-300 shadow-md shadow-luminet-lime/25 flex items-center justify-center gap-2 text-sm hover:scale-[1.01] active:scale-[0.99] cursor-pointer">
                Enviar y recibir propuesta
                <Send class="w-4 h-4" />
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs Section -->
  <section class="py-20 md:py-28 bg-white border-t border-gray-100">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-luminet-lime/10 text-luminet-lime text-xs font-bold tracking-wider uppercase mb-3">
          <HelpCircle class="w-3.5 h-3.5" /> FAQ
        </span>
        <h2 class="text-3xl md:text-5xl font-extrabold text-luminet-navy tracking-tight">
          Preguntas <span class="text-luminet-lime">Frecuentes</span>
        </h2>
        <p class="text-gray-500 mt-4 text-lg max-w-2xl mx-auto leading-relaxed">
          Respondemos de manera ágil a las principales dudas sobre la implementación, cobertura y alcances de nuestro servicio de {title}.
        </p>
      </div>

      <div class="space-y-4">
        {faqs.map((faq, idx) => (
          <div class="faq-accordion bg-luminet-gray rounded-2xl border border-gray-100 overflow-hidden transition-all duration-300">
            <button 
              type="button"
              class="faq-toggle w-full flex items-center justify-between px-6 py-5 text-left hover:bg-gray-100/50 transition-colors duration-300 focus:outline-none"
              data-index={idx}
            >
              <span class="text-base font-bold text-luminet-navy pr-4">
                {faq.q}
              </span>
              <span class="faq-symbol ml-4 shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-lg font-black transition-all duration-300 bg-white text-luminet-navy border border-gray-200">
                +
              </span>
            </button>
            <div class="faq-content hidden px-6 pb-6 border-t border-gray-100/30 pt-4">
              <p class="text-sm sm:text-base text-gray-500 leading-relaxed">
                {faq.a}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  // Dynamic Ticket Form Handler
  const supportForm = document.getElementById("support-ticket-form") as HTMLFormElement | null;
  const successBox = document.getElementById("quote-success");
  const resetBtn = document.getElementById("reset-form");

  supportForm?.addEventListener("submit", (e) => {
    e.preventDefault();
    supportForm.classList.add("hidden");
    successBox?.classList.remove("hidden");
  });

  resetBtn?.addEventListener("click", () => {
    supportForm?.reset();
    successBox?.classList.add("hidden");
    supportForm?.classList.remove("hidden");
  });

  // Smooth Accordion Handler
  const toggles = document.querySelectorAll(".faq-toggle");
  
  toggles.forEach((btn) => {
    btn.addEventListener("click", () => {
      const parent = btn.closest(".faq-accordion");
      const content = parent?.querySelector(".faq-content");
      const symbol = btn.querySelector(".faq-symbol");
      
      const isOpen = !content?.classList.contains("hidden");
      
      document.querySelectorAll(".faq-accordion").forEach((item) => {
        item.querySelector(".faq-content")?.classList.add("hidden");
        const itemSymbol = item.querySelector(".faq-symbol");
        if (itemSymbol) {
          itemSymbol.textContent = "+";
          itemSymbol.classList.remove("bg-luminet-lime", "text-luminet-navy", "border-transparent");
          itemSymbol.classList.add("bg-white", "text-luminet-navy", "border-gray-200");
        }
      });
      
      if (!isOpen) {
        content?.classList.remove("hidden");
        if (symbol) {
          symbol.textContent = "−";
          symbol.classList.add("bg-luminet-lime", "text-luminet-navy", "border-transparent");
          symbol.classList.remove("bg-white", "text-luminet-navy", "border-gray-200");
        }
      }
    });
  });
</script>
