---
import {
  Menu,
  ChevronDown,
  MessageCircle,
  X,
  ChevronRight,
} from "lucide-astro";
---

<header class="navbar-wrapper">
  <input type="checkbox" id="mobile-menu-toggle" class="mobile-menu-toggle" />

  <nav class="navbar">
    <div class="navbar-container">
      <!-- Logo -->
      <div class="navbar-brand">
        <a href="/" class="logo-link">
            <img src="/Logo-pt2.webp" alt="Logo" class="logo-img" style="width: 35px; height: auto;"/>
            <img src="/Logo-pt1.webp" alt="Logo" class="logo-img" style="width: 80px; height: auto;" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="navbar-menu desktop-only">
        <ul class="nav-list">
          <li class="nav-item">
            <a href="/" class="nav-link">Luminet</a>
          </li>

          <!-- Dropdown -->
          <li class="nav-item dropdown">
            <button class="nav-link dropdown-toggle">
              Soluciones <ChevronDown class="icon-small" />
            </button>
            <ul class="dropdown-menu">
              <li>
                <a href="/conectividad/" class="dropdown-item">Conectividad</a>
              </li>
              <li>
                <a href="/internet-dedicado/" class="dropdown-item"
                  >Internet Dedicado</a
                >
              </li>
              <li>
                <a href="/internet-pyme/" class="dropdown-item">Internet Asimétrico</a
                >
              </li>
              <li>
                <a href="/internet-satelital/" class="dropdown-item"
                  >Servicios TIC</a
                >
              </li>
              <li>
                <a href="/internet-eventos/" class="dropdown-item"
                  >Comunicaciones Unificadas</a
                >
              </li>
              <li>
                <a href="/alta-disponibilidad/" class="dropdown-item"
                  >Red WiFi Administrada</a
                >
              </li>
              <li>
                <a href="/servicios-administrados/" class="dropdown-item"
                  >Internet Satelital</a
                >
              </li>
              <li>
                <a href="/comunicaciones-unificadas/" class="dropdown-item"
                  >Internet Eventual</a
                >
              </li>
              
              <li>
                <a href="/ciberseguridad/" class="dropdown-item"
                  >Redes Privadas Virtuales</a
                >
              </li>
              <li>
                <a href="/video-vigilancia/" class="dropdown-item"
                  >Ciberseguridad</a
                >
              </li>
              <li><a href="/sd-wan/" class="dropdown-item">Data Centers</a></li>
              <li><a href="/site-map/" class="dropdown-item">Site Map</a></li>
            </ul>
          </li>

          <li class="nav-item"><a href="#" class="nav-link">¿Quienes somos?</a></li>
          <li class="nav-item"><a href="#" class="nav-link">Soporte</a></li>

          <!-- Divider -->
          <li class="nav-divider"></li>

          <li class="nav-item">
            <a href="#" class="nav-link highlight-link">
              Conectividad Para Empresas <ChevronRight class="icon-small" />
            </a>
          </li>
        </ul>
      </div>

      <!-- Actions -->
      <div class="navbar-actions">
        <a href="https://wa.me/..." class="btn-primary desktop-only">
          <span>Whatsapp</span>
          <MessageCircle class="icon-medium icon-light" />
        </a>

        <!-- Mobile Menu Button -->
        <label for="mobile-menu-toggle" class="mobile-menu-btn mobile-only">
          <Menu class="icon-large" />
        </label>
      </div>
    </div>
  </nav>

  <!-- Mobile Drawer Overlay -->
  <label for="mobile-menu-toggle" class="drawer-overlay"></label>

  <!-- Mobile Drawer -->
  <div class="mobile-drawer">
    <div class="drawer-header">
      <a href="/" class="logo-link">
        <img src="/Logo-pt2.webp" alt="Logo" class="logo-img" style="width: 35px; height: auto;"/>
            <img src="/Logo-pt1.webp" alt="Logo" class="logo-img" style="width: 80px; height: auto;" />
      </a>
      <label for="mobile-menu-toggle" class="drawer-close-btn">
        <X class="icon-medium" />
      </label>
    </div>

    <div class="drawer-content">
      <ul class="drawer-nav">
        <li><a href="/" class="drawer-link">Luminet</a></li>

        <!-- Mobile Accordion for Soluciones -->
        <li class="drawer-accordion">
          <details>
            <summary class="drawer-link drawer-accordion-summary">
              Soluciones
              <ChevronDown class="icon-medium accordion-icon" />
            </summary>
            <ul class="drawer-accordion-content">
              <li>
                <a href="/conectividad/" class="drawer-sublink">Conectividad</a>
              </li>
              <li>
                <a href="/internet-dedicado/" class="drawer-sublink"
                  >Internet Dedicado</a
                >
              </li>
              <li>
                <a href="/internet-pyme/" class="drawer-sublink"
                  >Internet Asimétrico</a
                >
              </li>
              <li>
                <a href="/internet-satelital/" class="drawer-sublink"
                  >Servicios TIC</a
                >
              </li>
              <li>
                <a href="/internet-eventos/" class="drawer-sublink"
                  >Comunicaciones Unificadas</a
                >
              </li>
              <li>
                <a href="/alta-disponibilidad/" class="drawer-sublink"
                  >Red WiFi Administrada</a
                >
              </li>
              <li>
                <a href="/servicios-administrados/" class="drawer-sublink"
                  >Internet Satelital</a
                >
              </li>
              <li>
                <a href="/comunicaciones-unificadas/" class="drawer-sublink"
                  >Internet Eventual</a
                >
              </li>
              <li>
                <a href="/ciberseguridad/" class="drawer-sublink"
                  >Redes Privadas Virtuales</a
                >
              </li>
              
              <li>
                <a href="/video-vigilancia/" class="drawer-sublink"
                  >Ciberseguridad</a
                >
              </li>
              <li><a href="/sd-wan/" class="drawer-sublink">Data Centers</a></li>

        <li><a href="#" class="drawer-link">¿Quienes somos?</a></li>
        <li><a href="#" class="drawer-link">Soporte</a></li>
        <li>
          <a href="#" class="drawer-link highlight-text"
            >Conectividad Para Empresas</a
          >
        </li>
      </ul>
    </div>

    <div class="drawer-footer">
      <a href="https://wa.me/..." class="btn-primary w-full">
        <span>Whatsapp</span>
        <MessageCircle class="icon-medium icon-dark" />
      </a>
    </div>
  </div>
</header>

<style>
  /* Base Reset & Variables mapping */
  .navbar-wrapper {
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .mobile-menu-toggle {
    display: none;
  }

  /* Navbar Styles */
  .navbar {
    width: 100%;
    background-color: rgba(0, 8, 41, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1rem 0;
  }

  .navbar-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Brand / Logo */
  .navbar-brand {
    flex: none;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .logo-text {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--text-light, #fff);
  }

  .logo-img {
    width: 3rem;
  }

  /* Desktop Menu */
  .navbar-menu {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-light, #fff);
    text-decoration: none;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .nav-link:hover {
    color: var(--primary, #2b59ff);
  }

  .highlight-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-divider {
    width: 1px;
    height: 1.25rem;
    background-color: rgba(255, 255, 255, 0.2);
  }

  /* Dropdown */
  .dropdown {
    position: relative;
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background-color: var(--bg-dark, #000829);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.75rem;
    padding: 0.5rem;
    width: 16rem;
    margin-top: 1rem;
    list-style: none;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
    z-index: 10;
  }

  .dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-item {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--text-light, #fff);
    text-decoration: none;
    font-size: 0.875rem;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }

  .dropdown-item:hover {
    background-color: rgba(43, 89, 255, 0.1);
  }

  /* Actions */
  .navbar-actions {
    flex: none;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background-color: #9def00;
    color: #000;
    font-weight: 700;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    text-decoration: none;
    transition: all 0.2s ease;
    border: none;
    cursor: pointer;
  }

  .btn-primary:hover {
    background-color: #9def00;
    transform: scale(1.05);
    box-shadow: 0 0 20px rgba(142, 219, 0, 0.3);
  }

  .btn-primary.w-full {
    width: 100%;
    background-color: #9def00;
    padding: 1rem 1.5rem;
    border-radius: 0.75rem;
    box-sizing: border-box;
  }

  .mobile-menu-btn {
    background: none;
    border: none;
    color: var(--text-light, #fff);
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Icons */
  .icon-small {
    width: 1rem;
    height: 1rem;
    opacity: 0.7;
  }
  .icon-medium {
    width: 1.25rem;
    height: 1.25rem;
  }
  .icon-large {
    width: 1.5rem;
    height: 1.5rem;
  }
  .icon-dark {
    fill: #000;
    color: #000;
  }

  /* Mobile Drawer Overlay */
  .drawer-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 1001;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  /* Mobile Drawer */
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 20rem;
    max-width: 100%;
    background-color: var(--bg-dark, #000829);
    color: var(--text-light, #fff);
    z-index: 1002;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    box-sizing: border-box;
    overflow-y: auto;
  }

  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .logo-img-small {
    width: 2.5rem;
  }
  .logo-text-small {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  .drawer-close-btn {
    background: none;
    border: none;
    color: var(--text-light, #fff);
    cursor: pointer;
    padding: 0.5rem;
  }

  .drawer-content {
    flex: 1;
  }

  .drawer-nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .drawer-link {
    display: block;
    padding: 0.75rem 1rem;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--text-light, #fff);
    text-decoration: none;
    border-radius: 0.75rem;
    transition: background-color 0.2s ease;
  }

  .drawer-link:hover {
    background-color: rgba(43, 89, 255, 0.2);
  }

  .highlight-text {
    color: var(--primary, #2b59ff);
  }

  /* Mobile Accordion */
  .drawer-accordion details > summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
  }

  .drawer-accordion details > summary::-webkit-details-marker {
    display: none;
  }

  .accordion-icon {
    transition: transform 0.2s ease;
  }

  .drawer-accordion details[open] > summary .accordion-icon {
    transform: rotate(180deg);
  }

  .drawer-accordion-content {
    list-style: none;
    margin-top: 0.5rem;
    margin-left: 1rem;
    padding-left: 1rem;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .drawer-sublink {
    display: block;
    padding: 0.5rem;
    color: var(--text-light, #fff);
    text-decoration: none;
    border-radius: 0.5rem;
    transition: background-color 0.2s ease;
  }

  .drawer-sublink:hover {
    background-color: rgba(43, 89, 255, 0.2);
  }

  .drawer-footer {
    margin-top: auto;
    padding-top: 2rem;
  }

  /* Toggle Logic */
  .mobile-menu-toggle:checked ~ .drawer-overlay {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-toggle:checked ~ .mobile-drawer {
    transform: translateX(0);
  }

  /* Media Queries */
  @media (min-width: 1024px) {
    .navbar-container {
      padding: 0 2rem;
    }
    .mobile-only {
      display: none;
    }
  }

  @media (max-width: 1023px) {
    .desktop-only {
      display: none;
    }
  }
</style>
