---
import { ChevronDown, ChevronRight, Menu, X } from 'lucide-astro';
---

<nav id="main-nav" style="position:fixed;top:0;left:0;right:0;z-index:50;background:rgba(15,46,101,0.85);backdrop-filter:blur(8px);transition:all 0.5s ease;">
  <div style="max-width:80rem;margin:0 auto;padding:0 1.5rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;height:80px;">

      <!-- Logo -->
      <a href="/" style="display:flex;align-items:center;gap:0.5rem;text-decoration:none;">
        <img src="/Logo-pt2.webp" alt="Logo" class="logo-img" style="width: 35px; height: auto;"/>
        <img src="/Logo-pt1.webp" alt="Logo" class="logo-img" style="width: 80px; height: auto;" />
      </a>

      <!-- Desktop menu -->
      <div id="desktop-menu" style="display:none;align-items:center;gap:0.25rem;">

        <a href="/" style="padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:rgba(209,213,219,1);text-decoration:none;transition:all 0.3s;">Luminet</a>

        <!-- Soluciones dropdown -->
        <div id="soluciones-wrapper" style="position:relative;">
          <button id="soluciones-btn" style="display:flex;align-items:center;gap:0.25rem;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:rgba(209,213,219,1);background:none;border:none;cursor:pointer;transition:all 0.3s;">
            Soluciones
            <ChevronDown id="sol-chevron" style="width:1rem;height:1rem;transition:transform 0.3s;" />
          </button>
          <div id="soluciones-dropdown" style="display:none;position:absolute;top:100%;left:0;margin-top:0.25rem;width:440px;background:#0F2E65;border:1px solid rgba(255,255,255,0.12);border-radius:0.75rem;box-shadow:0 20px 40px rgba(0,0,0,0.4);padding:1rem;z-index:100;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
              <a href="/conectividad" style="padding:0.5rem 0.75rem;font-size:0.875rem;color:rgba(209,213,219,1);border-radius:0.5rem;text-decoration:none;transition:all 0.2s;" class="sol-link">Conectividad</a>
              <a href="/internet-dedicado" style="padding:0.5rem 0.75rem;font-size:0.875rem;color:rgba(209,213,219,1);border-radius:0.5rem;text-decoration:none;transition:all 0.2s;" class="sol-link">Internet Dedicado</a>
              <a href="/internet-pyme" style="padding:0.5rem 0.75rem;font-size:0.875rem;color:rgba(209,213,219,1);border-radius:0.5rem;text-decoration:none;transition:all 0.2s;" class="sol-link">Internet Asimétrico</a>
              <a href="/servicios-administrados" style="padding:0.5rem 0.75rem;font-size:0.875rem;color:rgba(209,213,219,1);border-radius:0.5rem;text-decoration:none;transition:all 0.2s;" class="sol-link">Servicios TIC</a>
              <a href="/comunicaciones-unificadas" style="padding:0.5rem 0.75rem;font-size:0.875rem;color:rgba(209,213,219,1);border-radius:0.5rem;text-decoration:none;transition:all 0.2s;" class="sol-link">Comunicaciones Unificadas</a>
              <a href="/red-wifi" style="padding:0.5rem 0.75rem;font-size:0.875rem;color:rgba(209,213,219,1);border-radius:0.5rem;text-decoration:none;transition:all 0.2s;" class="sol-link">Red Wifi Administrada</a>
              <a href="/internet-satelital" style="padding:0.5rem 0.75rem;font-size:0.875rem;color:rgba(209,213,219,1);border-radius:0.5rem;text-decoration:none;transition:all 0.2s;" class="sol-link">Internet Satelital</a>
              <a href="/internet-eventos" style="padding:0.5rem 0.75rem;font-size:0.875rem;color:rgba(209,213,219,1);border-radius:0.5rem;text-decoration:none;transition:all 0.2s;" class="sol-link">Internet Eventual</a>
              <a href="/sd-wan" style="padding:0.5rem 0.75rem;font-size:0.875rem;color:rgba(209,213,219,1);border-radius:0.5rem;text-decoration:none;transition:all 0.2s;" class="sol-link">Redes Privadas Virtuales</a>
              <a href="/ciberseguridad" style="padding:0.5rem 0.75rem;font-size:0.875rem;color:rgba(209,213,219,1);border-radius:0.5rem;text-decoration:none;transition:all 0.2s;" class="sol-link">Ciberseguridad</a>
              <a href="/alta-disponibilidad" style="padding:0.5rem 0.75rem;font-size:0.875rem;color:rgba(209,213,219,1);border-radius:0.5rem;text-decoration:none;transition:all 0.2s;" class="sol-link">Data Centers</a>
            </div>
          </div>
        </div>

        <a href="/quienes-somos/" style="padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:rgba(209,213,219,1);text-decoration:none;transition:all 0.3s;">¿Quienes somos?</a>
        <a href="/#soporte" style="padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:rgba(209,213,219,1);text-decoration:none;transition:all 0.3s;">Soporte</a>

        <div style="width:1px;height:1.25rem;background:rgba(255,255,255,0.15);margin:0 0.5rem;"></div>

        <a href="/#contacto" style="display:flex;align-items:center;gap:0.25rem;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:rgba(209,213,219,1);text-decoration:none;transition:all 0.3s;">
          Conectividad para Empresas
          <ChevronRight style="width:1rem;height:1rem;" />
        </a>
      </div>

      <!-- Whatsapp button (desktop) -->
      <div id="desktop-cta" style="display:none;align-items:center;gap:1rem;">
        <a href="https://wa.me/1234567890" target="_blank" rel="noopener noreferrer" style="display:flex;align-items:center;gap:0.5rem;background:#78BE20;color:#0F2E65;padding:0.625rem 1.25rem;border-radius:9999px;font-size:0.875rem;font-weight:700;text-decoration:none;transition:all 0.3s;">
          <svg style="width:1rem;height:1rem;" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Whatsapp
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button id="mobile-toggle" style="display:flex;padding:0.5rem;border-radius:0.5rem;color:white;background:none;border:none;cursor:pointer;">
        <Menu id="menu-icon" style="width:1.5rem;height:1.5rem;" />
        <X id="close-icon" style="width:1.5rem;height:1.5rem;display:none;" />
      </button>

    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" style="display:none;border-top:1px solid rgba(255,255,255,0.1);background:rgba(15,46,101,0.98);backdrop-filter:blur(16px);">
    <div style="padding:1rem 1.5rem 1.5rem;display:flex;flex-direction:column;gap:0.25rem;">
      <a href="/" style="display:block;padding:0.75rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:rgba(209,213,219,1);text-decoration:none;">Luminet</a>

      <!-- Mobile Soluciones section -->
      <button id="mob-sol-btn" style="display:flex;align-items:center;justify-content:space-between;width:100%;padding:0.75rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:rgba(209,213,219,1);background:none;border:none;cursor:pointer;text-align:left;">
        Soluciones
        <ChevronDown id="mob-sol-chevron" style="width:1rem;height:1rem;transition:transform 0.3s;" />
      </button>
      <div id="mob-sol-dropdown" style="display:none;padding:0.5rem 0 0.5rem 1rem;border-left:2px solid rgba(120,190,32,0.4);margin-left:1rem;">
        <span style="display:block;padding:0.25rem 1rem;font-size:0.7rem;font-weight:700;color:rgba(156,163,175,1);text-transform:uppercase;letter-spacing:0.1em;">Nuestros Servicios</span>
        <a href="/conectividad" style="display:block;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;color:rgba(209,213,219,1);text-decoration:none;" class="mob-sol-link">Conectividad</a>
        <a href="/internet-dedicado" style="display:block;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;color:rgba(209,213,219,1);text-decoration:none;" class="mob-sol-link">Internet Dedicado</a>
        <a href="/internet-pyme" style="display:block;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;color:rgba(209,213,219,1);text-decoration:none;" class="mob-sol-link">Internet Asimétrico</a>
        <a href="/servicios-administrados" style="display:block;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;color:rgba(209,213,219,1);text-decoration:none;" class="mob-sol-link">Servicios TIC</a>
        <a href="/comunicaciones-unificadas" style="display:block;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;color:rgba(209,213,219,1);text-decoration:none;" class="mob-sol-link">Comunicaciones Unificadas</a>
        <a href="/red-wifi" style="display:block;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;color:rgba(209,213,219,1);text-decoration:none;" class="mob-sol-link">Red Wifi Administrada</a>
        <a href="/internet-satelital" style="display:block;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;color:rgba(209,213,219,1);text-decoration:none;" class="mob-sol-link">Internet Satelital</a>
        <a href="/internet-eventos" style="display:block;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;color:rgba(209,213,219,1);text-decoration:none;" class="mob-sol-link">Internet Eventual</a>
        <a href="/sd-wan" style="display:block;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;color:rgba(209,213,219,1);text-decoration:none;" class="mob-sol-link">Redes Privadas Virtuales</a>
        <a href="/ciberseguridad" style="display:block;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;color:rgba(209,213,219,1);text-decoration:none;" class="mob-sol-link">Ciberseguridad</a>
        <a href="/alta-disponibilidad" style="display:block;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;color:rgba(209,213,219,1);text-decoration:none;" class="mob-sol-link">Data Centers</a>
      </div>

      <a href="/quienes-somos/" style="display:block;padding:0.75rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:rgba(209,213,219,1);text-decoration:none;">¿Quienes somos?</a>
      <a href="/#soporte" style="display:block;padding:0.75rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:rgba(209,213,219,1);text-decoration:none;">Soporte</a>
      <a href="/#contacto" style="display:block;padding:0.75rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:500;color:rgba(209,213,219,1);text-decoration:none;">Conectividad para Empresas</a>
      <a href="https://wa.me/1234567890" target="_blank" rel="noopener noreferrer" style="display:flex;align-items:center;justify-content:center;gap:0.5rem;background:#78BE20;color:#0F2E65;padding:0.75rem 1.25rem;border-radius:9999px;font-size:0.875rem;font-weight:700;text-decoration:none;margin-top:1rem;">
        <svg style="width:1rem;height:1rem;" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        Whatsapp
      </a>
    </div>
  </div>
</nav>

<style>
  .sol-link:hover, .mob-sol-link:hover {
    background: rgba(255,255,255,0.08) !important;
    color: white !important;
  }
  @media (min-width: 768px) {
    #desktop-menu { display: flex !important; }
    #desktop-cta { display: flex !important; }
    #mobile-toggle { display: none !important; }
  }
</style>

<script>
  // Desktop Soluciones dropdown
  const solBtn = document.getElementById('soluciones-btn');
  const solDropdown = document.getElementById('soluciones-dropdown');
  const solChevron = document.getElementById('sol-chevron');
  let solOpen = false;

  solBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    solOpen = !solOpen;
    solDropdown!.style.display = solOpen ? 'block' : 'none';
    (solChevron as HTMLElement).style.transform = solOpen ? 'rotate(180deg)' : 'rotate(0deg)';
  });

  document.addEventListener('click', (e) => {
    const wrapper = document.getElementById('soluciones-wrapper');
    if (wrapper && !wrapper.contains(e.target as Node)) {
      solOpen = false;
      solDropdown!.style.display = 'none';
      (solChevron as HTMLElement).style.transform = 'rotate(0deg)';
    }
  });

  // Mobile menu toggle
  const mobileToggle = document.getElementById('mobile-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  let mobileOpen = false;

  mobileToggle?.addEventListener('click', () => {
    mobileOpen = !mobileOpen;
    mobileMenu!.style.display = mobileOpen ? 'block' : 'none';
    menuIcon!.style.display = mobileOpen ? 'none' : 'block';
    closeIcon!.style.display = mobileOpen ? 'block' : 'none';
  });

  // Mobile Soluciones toggle
  const mobSolBtn = document.getElementById('mob-sol-btn');
  const mobSolDropdown = document.getElementById('mob-sol-dropdown');
  const mobSolChevron = document.getElementById('mob-sol-chevron');
  let mobSolOpen = false;

  mobSolBtn?.addEventListener('click', () => {
    mobSolOpen = !mobSolOpen;
    mobSolDropdown!.style.display = mobSolOpen ? 'block' : 'none';
    (mobSolChevron as HTMLElement).style.transform = mobSolOpen ? 'rotate(180deg)' : 'rotate(0deg)';
  });
</script>
