---
import fs from "node:fs";
import path from "node:path";

const topRow = Array.from({ length: 11 }, (_, i) => i + 1);
const bottomRow = Array.from({ length: 10 }, (_, i) => i + 12);
const fadeMask = "linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent)";

// Detecta automáticamente la extensión real de cada logo en build (png/webp/etc.)
const alianzasDir = path.resolve("public/nuestrasAlianzas");
const extByNum = new Map<number, string>();
for (const file of fs.readdirSync(alianzasDir)) {
  const m = file.match(/^(\d+)\.(\w+)$/);
  if (m) extByNum.set(Number(m[1]), m[2]);
}
const logoSrc = (n: number) => `/nuestrasAlianzas/${n}.${extByNum.get(n) ?? "png"}`;
---

<section class="bg-[#f8f9fa] py-24 overflow-hidden" aria-label="Nuestras alianzas">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-14">
    <span class="text-[#2b59ff] text-xs font-bold uppercase tracking-[0.15em]">Nuestras Alianzas</span>
    <h2 class="text-[#000bb3] text-3xl md:text-4xl font-bold mt-2">Nuestras Alianzas</h2>
  </div>

  <!-- Fila 1: izquierda → derecha -->
  <div class="overflow-hidden py-3" style={`-webkit-mask-image:${fadeMask};mask-image:${fadeMask};`} aria-hidden="true">
    <div class="alianzas-track alianzas-rtl flex flex-row flex-nowrap w-max gap-6">
      {[...topRow, ...topRow].map((n) => (
        <div class="flex-none w-[220px] h-[150px] bg-white flex items-center justify-center rounded-[15px] border border-[#e2e8f0] p-4 transition-shadow duration-300 hover:shadow-lg">
          <img src={logoSrc(n)} alt={`Alianza ${n}`} loading="lazy" decoding="async" class="w-full h-full object-contain" />
        </div>
      ))}
    </div>
  </div>

  <!-- Fila 2: derecha → izquierda -->
  <div class="overflow-hidden py-3 mt-4" style={`-webkit-mask-image:${fadeMask};mask-image:${fadeMask};`} aria-hidden="true">
    <div class="alianzas-track alianzas-ltr flex flex-row flex-nowrap w-max gap-6">
      {[...bottomRow, ...bottomRow].map((n) => (
        <div class="flex-none w-[220px] h-[150px] bg-white flex items-center justify-center rounded-[15px] border border-[#e2e8f0] p-4 transition-shadow duration-300 hover:shadow-lg">
          <img src={logoSrc(n)} alt={`Alianza ${n}`} loading="lazy" decoding="async" class="w-full h-full object-contain" />
        </div>
      ))}
    </div>
  </div>

  <ul class="sr-only">
    {[...topRow, ...bottomRow].map((n) => (<li>Alianza {n}</li>))}
  </ul>
</section>
