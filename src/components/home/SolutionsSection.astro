---
import { ArrowRight } from 'lucide-astro';

const especialidades = [
  {
    eyebrow: 'PLANTA EXTERNA Y ÚLTIMA MILLA',
    title: 'Planta Externa y Última Milla',
    image: '/especialidades/integracion.webp',
    description: 'Despliegue de infraestructura de red en zonas urbanas, rurales y de difícil acceso. Donde la fibra no llega, llegamos nosotros mediante radioenlace de microondas.'
  },
  {
    eyebrow: 'CENTROS DE MANDO Y CONTROL',
    title: 'Construcción y Mantenimiento de C5, C4 y C2',
    image: '/especialidades/plataforma.webp',
    description: 'Diseño, equipamiento y operación de centros de mando y control para coordinación de seguridad pública. Solución llave en mano con soporte continuo.'
  },
  {
    eyebrow: 'VIDEO VIGILANCIA URBANA',
    title: 'Video Vigilancia Urbana',
    image: '/especialidades/Soluciones.webp',
    description: 'Construcción de redes de monitoreo inteligente para espacios públicos: cámaras, obra civil, equipamiento y pólizas de soporte. Reconocimiento de placas, conteo de personas y detección de conductas.'
  },
  {
    eyebrow: 'CIBERSEGURIDAD Y CONTRAINTELIGENCIA',
    title: 'Ciberseguridad y Contrainteligencia',
    image: '/especialidades/integracion.webp',
    description: 'Protección de redes gubernamentales contra amenazas externas. Monitoreo SOC 24/7 y protocolos de seguridad por capas para resguardar información crítica del Estado.'
  },
  {
    eyebrow: 'CONECTIVIDAD DEDICADA',
    title: 'Conectividad Dedicada para Dependencias',
    image: '/especialidades/conectividad.webp',
    description: 'Internet simétrico y dedicado con SLA garantizado para operaciones de misión crítica: sistemas de emergencia, plataformas ciudadanas y comunicaciones interinstitucionales.'
  },
  {
    eyebrow: 'SOFTWARE PROPIO',
    title: 'Software Propio de Gestión de Incidencias',
    image: '/especialidades/fabricaSoftware.webp',
    description: 'Plataforma desarrollada internamente para administrar reportes ciudadanos, incidencias de red y dashboards operativos. Sin dependencia de terceros.'
  }
];
---

<section id="especialidades" class="bg-[#F5F7FA] py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="mb-14">
      <p class="text-[#78BE20] text-xs font-semibold uppercase tracking-[0.15em] mb-2">Lo que hacemos</p>
      <h2 class="text-[#0F2E65] text-3xl md:text-4xl font-bold tracking-tight">Especialidades</h2>
      <div class="w-14 h-1 bg-[#78BE20] mt-4 rounded-full"></div>
    </div>

    <div class="relative space-y-6">
      {especialidades.map((esp, i) => (
        <div
          class="group relative rounded-[2rem] bg-[#0F2E65] overflow-hidden shadow-lg hover:shadow-2xl transition-shadow duration-500"
          style={`z-index: ${10 + i};`}
        >
          <div class="absolute top-0 left-0 right-0 h-1 bg-[#78BE20] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="flex flex-col lg:flex-row items-stretch">
            <div class="flex-1 p-8 md:p-10 lg:p-12">
              <span class="inline-block text-[#78BE20] text-[11px] font-bold uppercase tracking-[0.12em] mb-3">
                {esp.eyebrow}
              </span>
              <h3 class="text-white text-2xl md:text-3xl font-semibold mb-5 tracking-tight">
                {esp.title}
              </h3>

              <div class="w-full h-px bg-white/10 mb-6"></div>

              <p class="text-white/80 text-sm md:text-base leading-relaxed mb-8 max-w-2xl">
                {esp.description}
              </p>

              <button class="inline-flex items-center gap-2 bg-[#78BE20] text-[#0F2E65] px-6 py-3 rounded-full text-sm font-bold hover:bg-[#6aad1a] hover:shadow-lg hover:shadow-[#78BE20]/25 transition-all duration-300 group/btn">
                DESCUBRE MAS
                <ArrowRight class="w-4 h-4 group-hover/btn:translate-x-1 transition-transform duration-300" />
              </button>
            </div>

            <div class="lg:w-[340px] xl:w-[400px] flex-shrink-0 relative flex items-center justify-center p-6 lg:p-8 bg-[#0a1f45]/50">
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 bg-[#4169E1]/20 rounded-full blur-[60px] pointer-events-none"></div>
              <img
                alt={esp.title}
                class="relative z-10 w-full max-w-[260px] h-auto object-contain drop-shadow-2xl group-hover:scale-105 transition-transform duration-500"
                src={esp.image}
                loading="lazy"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
