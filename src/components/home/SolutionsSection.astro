---
const especialidades = [
  {
    title: 'Conectividad',
    image: '/especialidades/conectividad.webp',
    items: [
      'Enlaces de Internet de alta capacidad y disponibilidad',
      'Enlaces de interconexión de puntos',
      'Redes WiFi públicas y privadas en interiores y exteriores soportadas por la última tecnología disponible',
      'Servicios de equipamiento y administración de redes y servicios',
      'Soporte remoto y en sitio con cuadrillas e ingeniería especializada'
    ]
  },
  {
    title: 'Integración de Proyectos',
    image: '/especialidades/integracion.webp',
    items: [
      'Integración de proyectos de modernización, digitalización y construcciones inteligentes',
      'IoT, monitoreo, CCTV, control de acceso',
      'Sistemas de intrusión y sistemas de prevención de incendios',
      'Automatización y digitalización de procesos'
    ]
  },
  {
    title: 'Plataforma Integral de Almacenamiento',
    image: '/especialidades/plataforma.webp',
    items: [
      'Equipamiento de redes y herramientas para usuarios',
      'Mesas de ayuda con niveles 1 y 2',
      'Pólizas preventivas y de soporte de diferentes marcas del mercado',
      'Administración de RMAs'
    ]
  },
  {
    title: 'Soluciones de Video Vigilancia Urbana',
    image: '/especialidades/Soluciones.webp',
    items: [
      'Construcción y equipamiento de centros de monitoreo',
      'Redes de comunicación en zonas urbanas, rurales y unidades móviles',
      'Puntos de monitoreo inteligente, incluyendo materiales, equipamiento, obras civiles y pólizas de soporte'
    ]
  },
  {
    title: 'Fábrica de Software',
    image: '/especialidades/fabricaSoftware.webp',
    items: [
      'Desarrollo de aplicativos móviles y de escritorio',
      'Administración de bases de datos',
      'Análisis y protección de datos',
      'Migración de ambientes on-premise a cloud y viceversa',
      'Administración de recursos especializados en plataformas'
    ]
  }
];
---

<section id="solutions" class="solutions-section">
  <div class="container">
    <h2 class="section-title">Especialidades</h2>

    <div class="solutions-list">
      {especialidades.map((esp) => (
        <div class="solution-card">
          <div class="solution-info">
            <h3 class="sol-title">{esp.title}</h3>
            <div class="sol-divider"></div>
            <ul class="sol-bullets">
              {esp.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
          <div class="solution-visual">
            <div class="visual-circle"></div>
            <img src={esp.image} alt={esp.title} class="solution-img" loading="lazy" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .solutions-section {
    padding: 8rem 0;
    background: #f8f9fa;
  }

  .solutions-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .solution-card {
    background: #000839;
    border-radius: 40px;
    padding: clamp(2rem, 5vw, 4rem);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: white;
    position: relative;
    overflow: hidden;
    min-height: 400px;
  }

  .solution-info {
    flex: 1;
    z-index: 2;
  }

  .sol-category {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    display: block;
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  .sol-title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    margin-bottom: 2rem;
  }

  .sol-divider {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.2);
    margin-bottom: 2rem;
  }

  .sol-bullets {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0 0 1rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.9);
  }

  .sol-bullets li {
    margin: 0;
  }

  .btn-discover {
    display: inline-block;
    padding: 0.8rem 2.5rem;
    border: 1px solid white;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 700;
    color: white;
  }

  .btn-discover:hover {
    background: white;
    color: #000839;
  }

  .solution-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    min-height: 280px;
  }

  .visual-circle {
    position: absolute;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, #2b59ff 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.5;
  }

  .solution-img {
    position: relative;
    z-index: 1;
    max-width: 320px;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  @media (max-width: 992px) {
    .solution-card {
      flex-direction: column;
      text-align: center;
    }
    .sol-services {
      justify-content: center;
    }
    .sol-divider {
      display: none;
    }
    .solution-visual {
      display: none;
    }
  }
</style>
