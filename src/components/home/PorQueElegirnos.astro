---
import { Award, Globe, Network, Headphones } from 'lucide-astro';

const valores = [
  {
    Icon: Award,
    title: 'Experiencia',
    desc: 'Más de 25 años conectando a México con soluciones de telecomunicaciones de grado institucional para el sector público.',
  },
  {
    Icon: Globe,
    title: 'Cobertura',
    desc: 'Presencia nacional con puntos de conexión estratégicos que garantizan disponibilidad y continuidad en todo el país.',
  },
  {
    Icon: Network,
    title: 'Infraestructura propia',
    desc: 'Red de fibra óptica y radioenlaces de microondas con rutas directas a proveedores Tier 1.',
  },
  {
    Icon: Headphones,
    title: 'Soporte especializado',
    desc: 'Acompañamiento técnico 24/7 con SLA garantizado y monitoreo proactivo de tu red.',
  },
];
---

<section
  class="relative py-28 px-4 sm:px-6 lg:px-8 overflow-hidden bg-fixed bg-center bg-cover"
  style="background-image: linear-gradient(rgba(15,46,101,0.92), rgba(10,10,26,0.92)), url('/internet-hero.png');"
  aria-label="¿Por qué elegirnos?"
>
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="flex items-center justify-center gap-3 mb-5">
        <div class="w-12 h-1 bg-[#78BE20] rounded-full"></div>
        <p class="text-[#78BE20] text-sm font-semibold uppercase tracking-[0.15em]">Nuestra propuesta de valor</p>
        <div class="w-12 h-1 bg-[#78BE20] rounded-full"></div>
      </div>
      <h2 class="text-white text-4xl md:text-5xl font-bold leading-tight tracking-tight">
        ¿Por qué elegirnos?
      </h2>
      <p class="text-white/70 text-lg leading-relaxed mt-5">
        Respaldamos cada proyecto con experiencia, cobertura e infraestructura propia para que las instituciones nunca se detengan.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {valores.map((v) => (
        <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:border-[#78BE20]/50 hover:bg-white/10 transition-all duration-300">
          <div class="w-14 h-14 rounded-xl bg-[#78BE20]/15 flex items-center justify-center mb-5">
            <v.Icon class="w-7 h-7 text-[#78BE20]" />
          </div>
          <h3 class="text-white text-xl font-bold mb-3">{v.title}</h3>
          <p class="text-white/70 text-sm leading-relaxed">{v.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
