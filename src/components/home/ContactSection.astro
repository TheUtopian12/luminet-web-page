---
import {
  User,
  Phone,
  MessageSquare,
  ChevronDown,
  Building2,
  Mail,
  Send,
  ClipboardList,
} from "lucide-astro";
---

<section id="contacto" class="bg-white py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p
        class="text-[#78BE20] text-xs font-semibold uppercase tracking-[0.15em] mb-3"
      >
        Solicita tu propuesta personalizada
      </p><h2
        class="text-[#0F2E65] text-4xl md:text-5xl font-bold tracking-tight mb-3"
      >
        Contáctenos
      </h2><p class="text-gray-500 text-base max-w-md mx-auto">
        Cuéntanos sobre tu dependencia y te contactamos en menos de 24 horas
        hábiles.
      </p><div class="w-16 h-1 bg-[#78BE20] mx-auto mt-6 rounded-full"></div>
    </div><div class="grid lg:grid-cols-5 gap-12 items-stretch">
      <div class="lg:col-span-2 flex">
        <div class="relative w-full">
          <div
            class="absolute -inset-4 bg-[#0F2E65]/5 rounded-[2rem] -rotate-3"
          >
          </div><div class="relative bg-[#F8FAFC] rounded-2xl p-2 shadow-sm h-full">
            <img
              alt="Contáctanos"
              class="w-full h-full min-h-[420px] rounded-xl object-cover"
              src="/contactanos.webp"
            /><div
              class="absolute bottom-4 left-4 right-4 bg-white/95 backdrop-blur-sm rounded-xl p-4 shadow-lg border border-gray-100"
            >
              <p class="text-[#0F2E65] text-sm font-semibold">
                Respuesta garantizada
              </p><p class="text-gray-500 text-xs mt-0.5">
                En menos de 24 horas hábiles
              </p>
            </div>
          </div>
        </div>
      </div><form id="contact-form" class="lg:col-span-3 space-y-6">
        <div class="grid sm:grid-cols-2 gap-5">
          <div class="space-y-2">
            <label
              class="flex items-center gap-2 text-[#0F2E65] text-sm font-semibold"
              ><User class="lucide lucide-user w-4 h-4 text-[#78BE20]" />Nombre
              completo</label
            ><input
              required=""
              placeholder="Tu nombre"
              class="w-full bg-[#F8FAFC] border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-[#78BE20]/30 focus:border-[#78BE20] transition-all duration-200 placeholder:text-gray-400"
              type="text"
              value=""
              name="nombre"
            />
          </div><div class="space-y-2">
            <label
              class="flex items-center gap-2 text-[#0F2E65] text-sm font-semibold"
              ><Building2
                class="lucide lucide-building2 lucide-building-2 w-4 h-4 text-[#78BE20]"
              />Dependencia / Institución</label
            ><input
              required=""
              placeholder="Nombre de tu dependencia o institución"
              class="w-full bg-[#F8FAFC] border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-[#78BE20]/30 focus:border-[#78BE20] transition-all duration-200 placeholder:text-gray-400"
              type="text"
              value=""
              name="dependencia"
            />
          </div>
        </div><div class="grid sm:grid-cols-2 gap-5">
          <div class="space-y-2">
            <label
              class="flex items-center gap-2 text-[#0F2E65] text-sm font-semibold"
              ><Phone
                class="lucide lucide-phone w-4 h-4 text-[#78BE20]"
              />Teléfono</label
            ><input
              required=""
              placeholder="10 dígitos"
              class="w-full bg-[#F8FAFC] border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-[#78BE20]/30 focus:border-[#78BE20] transition-all duration-200 placeholder:text-gray-400"
              type="tel"
              value=""
              name="telefono"
            />
          </div><div class="space-y-2">
            <label
              class="flex items-center gap-2 text-[#0F2E65] text-sm font-semibold"
              ><Mail
                class="lucide lucide-mail w-4 h-4 text-[#78BE20]"
              />Email</label
            ><input
              required=""
              placeholder="correo@dependencia.gob.mx"
              class="w-full bg-[#F8FAFC] border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-[#78BE20]/30 focus:border-[#78BE20] transition-all duration-200 placeholder:text-gray-400"
              type="email"
              value=""
              name="email"
            />
          </div>
        </div><div class="space-y-2">
          <label
            class="flex items-center gap-2 text-[#0F2E65] text-sm font-semibold"
            ><ClipboardList
              class="lucide lucide-clipboard-list w-4 h-4 text-[#78BE20]"
            />Tipo de requerimiento</label
          ><div class="relative">
            <select
              required=""
              name="requerimiento"
              aria-label="Tipo de requerimiento"
              class="w-full bg-[#F8FAFC] border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-[#78BE20]/30 focus:border-[#78BE20] transition-all duration-200 placeholder:text-gray-400 appearance-none cursor-pointer pr-10"
              ><option value="">Selecciona una opción</option><option
                value="licitacion-publica">Licitación pública</option
              ><option value="adjudicacion-directa">Adjudicación directa</option
              ><option value="convenio-interinstitucional"
                >Convenio interinstitucional</option
              ><option value="asesoria-tecnica">Asesoría técnica</option><option
                value="otro">Otro</option
              ></select
            ><ChevronDown
              class="lucide lucide-chevron-down absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none"
            />
          </div>
        </div><div class="space-y-2">
          <label
            class="flex items-center gap-2 text-[#0F2E65] text-sm font-semibold"
            ><MessageSquare
              class="lucide lucide-message-square w-4 h-4 text-[#78BE20]"
            />Descripción del proyecto o necesidad</label
          ><textarea
            name="descripcion"
            rows="4"
            placeholder="Describe brevemente el proyecto, alcance o necesidad de tu dependencia..."
            class="w-full bg-[#F8FAFC] border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-[#78BE20]/30 focus:border-[#78BE20] transition-all duration-200 placeholder:text-gray-400 resize-none"
          ></textarea>
        </div><div
          id="form-error-msg"
          class="hidden p-4 text-sm text-red-700 bg-red-50 rounded-xl border border-red-100"
          role="alert"
        >
        </div><div class="pt-2">
          <button
            type="submit"
            id="submit-btn"
            class="group inline-flex items-center gap-3 bg-[#0F2E65] text-white px-8 py-4 rounded-full text-sm font-bold hover:bg-[#0a1f45] hover:shadow-lg hover:shadow-[#0F2E65]/20 transition-all duration-300"
            ><span id="btn-text">Solicitar información para mi dependencia</span
            ><Send
              class="lucide lucide-send w-4 h-4 group-hover:translate-x-1 transition-transform"
            /></button>
        </div><p class="text-gray-400 text-xs">
          Atendemos procesos de licitación y adjudicación directa. Tu
          información es confidencial.
        </p>
      </form><div
        id="success-card"
        class="hidden lg:col-span-3 bg-[#F8FAFC] border border-gray-100 rounded-2xl p-8 text-center space-y-6 shadow-sm"
      >
        <div
          class="inline-flex items-center justify-center w-16 h-16 bg-[#78BE20]/10 text-[#78BE20] rounded-full mx-auto"
        >
          <svg
            class="w-8 h-8"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M5 13l4 4L19 7"></path></svg>
        </div><div class="space-y-2">
          <h3 class="text-[#0F2E65] text-2xl font-bold">
            ¡Mensaje enviado con éxito!
          </h3><p class="text-gray-500 max-w-md mx-auto">
            Gracias por contactarnos. Hemos recibido tu información
            correctamente. Un asesor se pondrá en contacto contigo en menos de
            24 horas hábiles.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initContactForm() {
    const form = document.getElementById("contact-form") as HTMLFormElement;
    const submitBtn = document.getElementById(
      "submit-btn",
    ) as HTMLButtonElement;
    const btnText = document.getElementById("btn-text");
    const errorMsg = document.getElementById("form-error-msg");
    const successCard = document.getElementById("success-card");

    if (!form || !submitBtn) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (errorMsg) {
        errorMsg.classList.add("hidden");
        errorMsg.textContent = "";
      }

      const formData = new FormData(form);
      const nombre = formData.get("nombre") as string;
      const correo = formData.get("email") as string;
      const telefono = formData.get("telefono") as string;
      const empresa = formData.get("dependencia") as string;
      const solucion = formData.get("requerimiento") as string;
      const mensaje = formData.get("descripcion") as string;

      const solucionMapeada =
        {
          "licitacion-publica": "Licitación pública",
          "adjudicacion-directa": "Adjudicación directa",
          "convenio-interinstitucional": "Convenio interinstitucional",
          "asesoria-tecnica": "Asesoría técnica",
          otro: "Otro",
        }[solucion] || solucion;

      const params = new URLSearchParams();
      params.append("nombre", nombre);
      params.append("correo", correo);
      params.append("telefono", telefono);
      params.append("empresa", empresa || "No especificada");
      params.append("solucion", solucionMapeada);
      params.append("mensaje", mensaje || "Sin descripción");

      submitBtn.disabled = true;
      if (btnText) btnText.textContent = "Enviando...";

      try {
        await fetch("https://odoo.wispi.mx/form/leadluminet", {
          method: "POST",
          mode: "no-cors",
          headers: {
            "Content-Type": "application/x-www-form-urlencoded",
          },
          body: params.toString(),
        });

        form.classList.add("hidden");
        if (successCard) {
          successCard.classList.remove("hidden");
        }
      } catch (err) {
        console.error("Error enviando formulario:", err);
        if (errorMsg) {
          errorMsg.textContent =
            "Ocurrió un error al enviar tu solicitud. Por favor, inténtalo de nuevo más tarde.";
          errorMsg.classList.remove("hidden");
        }
        submitBtn.disabled = false;
        if (btnText)
          btnText.textContent = "Solicitar información para mi dependencia";
      }
    });
  }

  initContactForm();
  document.addEventListener("astro:page-load", initContactForm);
</script>
