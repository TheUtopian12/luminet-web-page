---
import { Phone, MessageCircle, Mail, Clock } from 'lucide-astro';

const telefonos = [
  { label: 'Soporte y atención a clientes', value: '844 379 0201', href: 'tel:8443790201' },
];
---

<section id="soporte" class="bg-[#0F2E65] py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <div class="flex items-center justify-center gap-3 mb-5">
        <div class="w-12 h-1 bg-[#78BE20] rounded-full"></div>
        <p class="text-[#78BE20] text-sm font-semibold uppercase tracking-[0.15em]">Estamos para ayudarte</p>
        <div class="w-12 h-1 bg-[#78BE20] rounded-full"></div>
      </div>
      <h2 class="text-white text-4xl md:text-5xl font-bold tracking-tight">Soporte Técnico</h2>
      <p class="text-white/70 text-lg leading-relaxed mt-5">
        Nuestro equipo de soporte está disponible las 24 horas, los 365 días del año, para garantizar la continuidad de tu operación.
      </p>
    </div>

    <div class="grid gap-6 max-w-md mx-auto">
      {telefonos.map((t) => (
        <a
          href={t.href}
          class="group flex items-center gap-4 bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10 hover:border-[#78BE20]/50 hover:bg-white/10 transition-all duration-300"
        >
          <div class="w-14 h-14 rounded-xl bg-[#78BE20]/15 flex items-center justify-center flex-shrink-0 group-hover:bg-[#78BE20]/25 transition-colors">
            <Phone class="w-7 h-7 text-[#78BE20]" />
          </div>
          <div>
            <p class="text-white/60 text-xs font-semibold uppercase tracking-[0.1em] mb-1">{t.label}</p>
            <p class="text-white text-2xl font-bold">{t.value}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-10">
      <a
        href="https://wa.me/818136481848"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#78BE20] text-[#0F2E65] px-6 py-3 rounded-full text-sm font-bold hover:bg-[#6aad1a] transition-colors"
      >
        <MessageCircle class="w-4 h-4" /> Soporte por WhatsApp
      </a>
      <a
        href="mailto:contactogobierno@luminet.com.mx"
        class="inline-flex items-center gap-2 border border-white/30 text-white px-6 py-3 rounded-full text-sm font-semibold hover:bg-white/10 transition-colors"
      >
        <Mail class="w-4 h-4" /> contactogobierno@luminet.com.mx
      </a>
    </div>

    <p class="flex items-center justify-center gap-2 text-white/50 text-sm mt-8">
      <Clock class="w-4 h-4 text-[#78BE20]" /> Servicio 24 horas, los 365 días del año.
    </p>
  </div>
</section>
