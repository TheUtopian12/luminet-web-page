---
import { Phone, Mail, ArrowRight } from 'lucide-astro';
---

<section id="soporte" class="relative overflow-hidden bg-gradient-to-br from-[#0F2E65] to-[#0a1f45] py-20 md:py-28 px-4 sm:px-6 lg:px-8">
  <!-- glows -->
  <div class="pointer-events-none absolute -top-24 -right-24 w-[30rem] h-[30rem] rounded-full bg-[#78BE20]/10 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-32 -left-24 w-[26rem] h-[26rem] rounded-full bg-[#1e4a9e]/25 blur-3xl"></div>

  <div class="relative z-10 max-w-7xl mx-auto grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- Copy -->
    <div>
      <div class="flex items-center gap-3 mb-6">
        <span class="w-10 h-px bg-[#78BE20]"></span>
        <span class="text-[#78BE20] text-sm font-semibold uppercase tracking-[0.18em]">Estamos para ayudarte</span>
      </div>
      <h2 class="text-white text-4xl md:text-5xl font-bold tracking-tight mb-6">Soporte Técnico</h2>
      <p class="text-white/70 text-lg leading-relaxed mb-8 max-w-lg">
        Nuestro equipo está disponible las 24 horas, los 365 días del año, para garantizar la
        continuidad de tu operación.
      </p>
      <div class="inline-flex items-center gap-2.5 bg-white/5 border border-white/10 rounded-full pl-3 pr-5 py-2">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#78BE20] opacity-60"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[#78BE20]"></span>
        </span>
        <span class="text-white/80 text-sm font-medium">Servicio 24/7 · los 365 días del año</span>
      </div>
    </div>

    <!-- Contact card -->
    <div class="bg-white/[0.06] backdrop-blur-sm border border-white/12 rounded-3xl p-8 md:p-10">
      <!-- Teléfono -->
      <a href="tel:8443790201" class="group flex items-center gap-5 pb-8 border-b border-white/10">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#78BE20] to-[#5a9416] flex items-center justify-center flex-shrink-0 shadow-lg shadow-[#78BE20]/25">
          <Phone class="w-8 h-8 text-[#0F2E65]" />
        </div>
        <div>
          <p class="text-white/55 text-xs font-semibold uppercase tracking-[0.12em] mb-1.5">Soporte y atención a clientes</p>
          <p class="text-white text-3xl font-extrabold tracking-tight group-hover:text-[#78BE20] transition-colors">844 379 0201</p>
        </div>
      </a>

      <!-- Acciones -->
      <div class="flex flex-col gap-3 mt-8">
        <a
          href="mailto:contactogobierno@luminet.com.mx"
          class="group flex items-center justify-between gap-3 bg-white/5 border border-white/15 text-white px-6 py-4 rounded-2xl text-sm font-semibold hover:bg-white/10 hover:border-white/30 transition-all"
        >
          <span class="flex items-center gap-2.5 min-w-0"><Mail class="w-5 h-5 text-[#78BE20] flex-shrink-0" /> <span class="truncate">contactogobierno@luminet.com.mx</span></span>
          <ArrowRight class="w-4 h-4 flex-shrink-0 group-hover:translate-x-1 transition-transform" />
        </a>
      </div>
    </div>
  </div>
</section>
